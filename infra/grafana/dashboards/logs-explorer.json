{
  "__inputs": [
    {
      "name": "DS_LOKI",
      "label": "Loki",
      "description": "Loki datasource",
      "type": "datasource",
      "pluginId": "loki",
      "pluginName": "Loki"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "loki",
      "name": "Loki",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "logs",
      "name": "Logs",
      "version": ""
    },
    {
      "type": "panel",
      "id": "row",
      "name": "Row",
      "version": ""
    }
  ],
  "uid": "worldview-logs-explorer",
  "title": "Worldview \u2014 Logs Explorer",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "schemaVersion": 39,
  "tags": [],
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": {
          "type": "loki",
          "uid": "loki"
        },
        "query": "label_values({job=~\".+\"}, container)",
        "multi": true,
        "includeAll": true,
        "allValue": ".+",
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        },
        "refresh": 2,
        "sort": 1
      },
      {
        "name": "level",
        "label": "Level",
        "type": "custom",
        "multi": true,
        "includeAll": false,
        "query": "debug,info,warning,error,critical",
        "options": [
          {
            "text": "debug",
            "value": "debug",
            "selected": false
          },
          {
            "text": "info",
            "value": "info",
            "selected": true
          },
          {
            "text": "warning",
            "value": "warning",
            "selected": true
          },
          {
            "text": "error",
            "value": "error",
            "selected": true
          },
          {
            "text": "critical",
            "value": "critical",
            "selected": true
          }
        ],
        "current": {
          "selected": true,
          "text": [
            "info",
            "warning",
            "error",
            "critical"
          ],
          "value": [
            "info",
            "warning",
            "error",
            "critical"
          ]
        }
      },
      {
        "name": "search",
        "label": "Search",
        "type": "textbox",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Log Volume Overview",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 100,
      "panels": []
    },
    {
      "id": 1,
      "title": "Log Volume by Service",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$service\"} [1m])) by (container)",
          "legendFormat": "{{container}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "id": 2,
      "title": "Error Log Volume",
      "type": "timeseries",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 6,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "targets": [
        {
          "expr": "sum(count_over_time({container=~\"$service\"} |= \"error\" [1m])) by (container)",
          "legendFormat": "{{container}}",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "linear",
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      }
    },
    {
      "type": "row",
      "title": "Log Stream",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "id": 101,
      "panels": []
    },
    {
      "id": 3,
      "title": "Log Stream",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 16,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "expr": "{container=~\"$service\"} | json | level=~\"$level\" |= \"$search\" | line_format \"{{.timestamp}} [{{.level}}] {{.service}}: {{.event}}\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "wrapLogMessage": true
      }
    },
    {
      "type": "row",
      "title": "Error Details",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 24
      },
      "id": 102,
      "panels": []
    },
    {
      "id": 4,
      "title": "Recent Errors",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "targets": [
        {
          "expr": "{container=~\"$service\"} | json | level=\"error\" |= \"$search\"",
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "loki"
          }
        }
      ],
      "options": {
        "showTime": true,
        "sortOrder": "Descending",
        "enableLogDetails": true,
        "wrapLogMessage": true
      }
    }
  ]
}