{
  "uid": "eodhd-health-v1",
  "title": "EODHD API Health",
  "editable": true,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "schemaVersion": 39,
  "tags": ["eodhd", "market-ingestion", "quota"],
  "timezone": "browser",
  "panels": [
    {
      "type": "row",
      "title": "Quota Health",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "type": "gauge",
      "title": "Monthly Quota Utilization",
      "description": "s2_eodhd_monthly_credits_used / s2_eodhd_monthly_credits_limit — updated when GET /api/v1/eodhd/quota/status is polled",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 1 },
      "targets": [
        {
          "expr": "s2_eodhd_monthly_credits_used / clamp_min(s2_eodhd_monthly_credits_limit, 1) * 100",
          "legendFormat": "Quota %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Credits Used This Month",
      "description": "s2_eodhd_monthly_credits_used — gauge updated by the quota status endpoint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "targets": [
        {
          "expr": "s2_eodhd_monthly_credits_used",
          "legendFormat": "Used",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Monthly Credit Limit",
      "description": "s2_eodhd_monthly_credits_limit — configured hard ceiling",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 5 },
      "targets": [
        {
          "expr": "s2_eodhd_monthly_credits_limit",
          "legendFormat": "Limit",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    },
    {
      "type": "gauge",
      "title": "Daily Budget Headroom",
      "description": "s2_eodhd_daily_budget_headroom = (allotted - spent) / allotted; negative = over daily budget",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 1 },
      "targets": [
        {
          "expr": "s2_eodhd_daily_budget_headroom * 100",
          "legendFormat": "Headroom %",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": -50,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0 },
              { "color": "green", "value": 20 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Response Cache Hit Rate",
      "description": "s2_eodhd_cache_hits_total / (hits + misses) — high hit rate = fewer live EODHD calls",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "targets": [
        {
          "expr": "rate(s2_eodhd_cache_hits_total[5m]) / clamp_min(rate(s2_eodhd_cache_hits_total[5m]) + rate(s2_eodhd_cache_misses_total[5m]), 0.001) * 100",
          "legendFormat": "Hit Rate %",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "green", "value": 80 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Circuit Breaker",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 }
    },
    {
      "type": "stat",
      "title": "Circuit Breaker State",
      "description": "max(s2_eodhd_circuit_breaker_state) — 0=CLOSED (healthy), 1=OPEN (blocking), 2=HALF_OPEN (probing)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "targets": [
        {
          "expr": "max(s2_eodhd_circuit_breaker_state)",
          "legendFormat": "State",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "CLOSED", "color": "green" },
                "1": { "text": "OPEN", "color": "red" },
                "2": { "text": "HALF_OPEN", "color": "yellow" }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "stat",
      "title": "Quota-Blocked Tasks",
      "description": "s2_eodhd_quota_blocked_total — tasks rejected because monthly quota was exhausted, by dataset_type",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 10 },
      "targets": [
        {
          "expr": "sum(s2_eodhd_quota_blocked_total)",
          "legendFormat": "Blocked (total)",
          "refId": "A"
        }
      ],
      "options": {
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Request Rates & Latency",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "type": "timeseries",
      "title": "API Requests Rate by Endpoint & Tier",
      "description": "rate(s2_eodhd_requests_total[5m]) — labeled by endpoint, status_code, symbol_tier",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "targets": [
        {
          "expr": "rate(s2_eodhd_requests_total[5m])",
          "legendFormat": "{{endpoint}} [{{symbol_tier}}] {{status_code}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "HTTP 429 (Rate-Limited) Rate",
      "description": "rate(s2_eodhd_rate_limited_total[5m]) — labeled by endpoint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "targets": [
        {
          "expr": "rate(s2_eodhd_rate_limited_total[5m])",
          "legendFormat": "429 {{endpoint}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "custom": { "fillOpacity": 20 }
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Request Latency P50 / P95 by Endpoint",
      "description": "histogram_quantile on s2_eodhd_request_duration_seconds — labeled by endpoint",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "targets": [
        {
          "expr": "histogram_quantile(0.5, rate(s2_eodhd_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P50 {{endpoint}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, rate(s2_eodhd_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95 {{endpoint}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" },
        "overrides": []
      }
    }
  ]
}
