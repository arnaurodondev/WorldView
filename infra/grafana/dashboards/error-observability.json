{
  "__inputs": [],
  "__requires": [],
  "annotations": {
    "list": []
  },
  "description": "Error observability — Sentry initialisation, unhandled exception rates, and rate-limiter drop tracking across all 10 backend services",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "refresh": "1m",
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["loki", "sentry", "errors", "observability"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values(service)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "service",
        "options": [],
        "query": {
          "label": "service",
          "refId": "StandardVariableQuery",
          "stream": "{job=~\".+\"}",
          "type": 1
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Service"
      }
    ]
  },
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "Error Observability",
  "uid": "worldview-error-observability",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "row",
      "title": "Exception Rates",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Unhandled Exception Rate — per service",
      "description": "Count of structlog 'unhandled_exception' events per service per 5-minute window. Baseline should be near-zero in healthy operation. A spike here means 500-errors are occurring and being captured by register_error_handlers().",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (count_over_time({job=~\".+\", service=~\"$service\"} |= \"unhandled_exception\" | json | event = `unhandled_exception` [5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi", "sort": "desc" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 10 },
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Sentry Rate-Limiter",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "stat",
      "title": "Sentry Events Rate-Limited (last 24h)",
      "description": "Total count of Sentry events dropped by the per-fingerprint rate-limiter in the last 24 hours. Non-zero means a single exception class is firing frequently enough to exhaust the free-tier quota — investigate the fingerprint in Sentry.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({job=~\".+\", service=~\"$service\"} |= \"sentry_event_rate_limited\" | json | event = `sentry_event_rate_limited` [24h]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["sum"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short"
        },
        "overrides": []
      }
    },
    {
      "type": "timeseries",
      "title": "Sentry Events Rate-Limited — over time",
      "description": "Time series of rate-limiter drops. A sustained series of drops means a repeating exception is exhausting quota — find the fingerprint in Sentry and fix the root cause.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 18, "x": 6, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (count_over_time({job=~\".+\", service=~\"$service\"} |= \"sentry_event_rate_limited\" | json | event = `sentry_event_rate_limited` [5m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1 },
          "unit": "short",
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      }
    },
    {
      "type": "row",
      "title": "Sentry Initialisation Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "title": "Sentry Init Status — per service (last 1h)",
      "description": "Shows whether each service has Sentry enabled, disabled, or failed to initialise. 'sentry_disabled' in production = someone forgot to set SENTRY_ENABLED=true for that service. 'sentry_init_failed' = DSN misconfigured or Sentry unreachable at startup.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service, event) (count_over_time({job=~\".+\", service=~\"$service\"} |~ \"sentry_initialised|sentry_disabled|sentry_init_failed\" | json | event =~ `sentry_initialised|sentry_disabled|sentry_init_failed` [1h]))",
          "legendFormat": "{{service}} — {{event}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "service", "desc": false }]
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "event" },
            "properties": [
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "sentry_initialised": { "color": "green", "text": "✅ active" } } },
                  { "type": "value", "options": { "sentry_disabled": { "color": "yellow", "text": "⏸ disabled" } } },
                  { "type": "value", "options": { "sentry_init_failed": { "color": "red", "text": "❌ failed" } } }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "type": "row",
      "title": "Top Exception Types",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 21 },
      "collapsed": false,
      "panels": []
    },
    {
      "type": "table",
      "title": "Top Exception Types (last 24h)",
      "description": "Exception types grouped by service — extracted from the 'path' field of unhandled_exception log events. Gives on-call a quick 'what is failing and where' view without opening Sentry. The 'path' field shows the HTTP endpoint that triggered the exception.",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 22 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(10, sum by (service, path) (count_over_time({job=~\".+\", service=~\"$service\"} |= \"unhandled_exception\" | json | event = `unhandled_exception` [24h])))",
          "legendFormat": "{{service}} — {{path}}",
          "refId": "A",
          "instant": true
        }
      ],
      "options": {
        "footer": { "show": false },
        "showHeader": true,
        "sortBy": [{ "displayName": "Value", "desc": true }]
      },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": []
      }
    }
  ]
}
