# platform.env — Cross-service production variables
# Copy to worldview-gitops/env/prod/platform.env and fill in values.
# Source this file before running make prod:
#   export $(grep -v '^#' env/prod/platform.env | xargs)
#
# These variables are read directly by docker-compose.prod.yml (${DOMAIN}, etc.)

# ── Domain ────────────────────────────────────────────────────────────────────
# Root domain. All subdomains are derived from this:
#   ${DOMAIN}         → worldview-web (Next.js frontend)
#   api.${DOMAIN}     → api-gateway (REST API)
#   ws.${DOMAIN}      → alert service (WebSocket)
#   grafana.${DOMAIN} → Grafana monitoring
#   www.${DOMAIN}     → redirected to ${DOMAIN} by Traefik
DOMAIN=worldview.example.com

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
# Email for ACME certificate expiry warnings (sent 30 and 7 days before expiry).
# Must be a real email address you monitor.
ACME_EMAIL=ops@example.com

# ── Zitadel OIDC ──────────────────────────────────────────────────────────────
# Zitadel Cloud instance URL. Format: https://<instance-name>.zitadel.cloud
# Get this from Zitadel Cloud console after creating your instance.
ZITADEL_URL=https://worldview.zitadel.cloud

# Zitadel PKCE application Client ID (no secret — PKCE uses none).
# Get this from Zitadel console → Projects → worldview → Applications → worldview-web → Client ID.
ZITADEL_CLIENT_ID=<client-id-from-zitadel>

# ── WebSocket ──────────────────────────────────────────────────────────────────
# WebSocket base URL for the browser to connect to S10 alert service.
# Must be wss:// (not ws://) — this signals HTTPS deployment (BP-324).
# Traefik routes this at: ws.${DOMAIN}:443 → alert:8010
# Default matches the Traefik alert router rule; only override if you change the subdomain.
NEXT_PUBLIC_WS_BASE_URL=wss://ws.worldview.example.com
