# syntax=docker/dockerfile:1
# Extends timescale/timescaledb:latest-pg16 (Alpine 3.21) with Apache AGE for
# the knowledge-graph service.
#
# Notes:
#   - timescaledb:latest-pg16 is Alpine-based (musl libc; use apk, not apt-get)
#   - PG16 was built --with-llvm using llvm19; PGXS needs llvm19-dev at build time
#   - Alpine 3.21 ships up to clang17 → symlink clang17 → clang for PGXS
#   - AGE tags use the format PG<ver>/<version>-rc0 (e.g. PG16/v1.5.0-rc0)
#     git clone --branch can't handle slash-containing tag names directly;
#     we use git fetch + checkout FETCH_HEAD instead.
#
# Build time: ~5-10 min on first `docker compose ... up --build` (cached after).
FROM timescale/timescaledb:latest-pg16

USER root

# Latest stable AGE release for PG16
ARG AGE_TAG=PG16/v1.5.0-rc0

RUN apk add --no-cache --virtual .build-deps \
        build-base \
        git \
        perl \
        clang17 \
        llvm19-dev \
        readline-dev \
        zlib-dev \
        flex \
        bison \
    # PGXS hard-codes CLANG=clang-<N> where N=LLVM version (19 here).
    # Alpine 3.21 only ships up to clang17; override via make variable.
    # LLVM bitcode generated by clang17 is forward-compatible with llvm19 at JIT-load time.
    && mkdir /tmp/age && cd /tmp/age \
    && git init \
    && git remote add origin https://github.com/apache/age.git \
    && git fetch --depth 1 origin "refs/tags/${AGE_TAG}" \
    && git checkout FETCH_HEAD \
    && make CLANG=/usr/bin/clang-17 \
    && make install \
    && rm -rf /tmp/age \
    && apk del .build-deps
