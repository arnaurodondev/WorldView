# nlp-pipeline — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile runtime).
# Infrastructure hostnames resolve to Docker service names, not localhost.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

NLP_PIPELINE_HOST=0.0.0.0
NLP_PIPELINE_PORT=8006
NLP_PIPELINE_DEBUG=false

# Database (Docker internal hostname: postgres)
NLP_PIPELINE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/nlp_db

# Intelligence database (shared with S6/S7 — same postgres, different DB)
NLP_PIPELINE_INTELLIGENCE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intelligence_db

# Kafka (Docker internal listener: kafka:29092)
NLP_PIPELINE_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
NLP_PIPELINE_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Storage (MinIO — Docker internal: minio:9000)
NLP_PIPELINE_STORAGE_ENDPOINT=http://minio:9000
# Dev default — replace with real credentials for production (never commit real credentials)
NLP_PIPELINE_STORAGE_ACCESS_KEY=minioadmin
NLP_PIPELINE_STORAGE_SECRET_KEY=minioadmin

# Valkey (Docker internal hostname: valkey)
NLP_PIPELINE_VALKEY_URL=redis://valkey:6379/0

# Auth
# Skip JWKS fetch in test/dev compose profiles that have no api-gateway container.
NLP_PIPELINE_INTERNAL_JWT_SKIP_VERIFICATION=true

# PLAN-0093 A-1 / F-LIVE-001 — required: the startup_assert helper refuses to start
# when internal_jwt_skip_verification=True AND APP_ENV is unset.
APP_ENV=development

# ── DeepInfra LLM provider keys (PLAN-0096 W2 T-W2-02) ──────────────────────
# The full set of NLP_PIPELINE_*_API_KEY env vars listed here must be supplied
# via the private worldview-gitops repo (`make fetch-secrets`). Leaving any
# of these empty silently falls back to local Ollama — which is unsupported
# on production and causes worker starvation (BP-563). The canonical key is
# the DeepInfra account key; the same literal is mirrored into each var
# below so per-worker provider routing decisions stay independent.
#
# Required by the embedding consumer + on-demand embed API:
# NLP_PIPELINE_EMBEDDING_API_KEY=<deepinfra-key>
# Required by deep extraction (kept here for completeness — owned by KG):
# NLP_PIPELINE_EXTRACTION_API_KEY=<deepinfra-key>
# Required by ArticleRelevanceScoringWorker (PRD-0026 Flow B). Empty →
# silent Ollama fallback (BP-563 / PLAN-0096 W2 T-W2-02 deferred from PLAN-0095 W4):
# NLP_PIPELINE_RELEVANCE_SCORING_API_KEY=<deepinfra-key>
# Required by UnresolvedResolutionWorker (PLAN-0033). Empty → Ollama fallback:
# NLP_PIPELINE_UNRESOLVED_RESOLUTION_API_KEY=<deepinfra-key>
