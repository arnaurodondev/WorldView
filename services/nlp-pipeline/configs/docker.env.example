# nlp-pipeline — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile runtime).
# Infrastructure hostnames resolve to Docker service names, not localhost.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

NLP_PIPELINE_HOST=0.0.0.0
NLP_PIPELINE_PORT=8006
NLP_PIPELINE_DEBUG=false

# Database — nlp_db lives on the dedicated OLAP instance (workload split 2026-06-08;
# Docker internal hostname: postgres-intelligence). See
# docs/audits/2026-06-08-postgres-workload-split.md.
NLP_PIPELINE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres-intelligence:5432/nlp_db

# Intelligence database (shared with S7 — same OLAP instance, different DB)
NLP_PIPELINE_INTELLIGENCE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres-intelligence:5432/intelligence_db

# Kafka (Docker internal listener: kafka:29092)
NLP_PIPELINE_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
NLP_PIPELINE_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Storage (MinIO — Docker internal: minio:9000)
NLP_PIPELINE_STORAGE_ENDPOINT=http://minio:9000
# Dev default — replace with real credentials for production (never commit real credentials)
NLP_PIPELINE_STORAGE_ACCESS_KEY=minioadmin
NLP_PIPELINE_STORAGE_SECRET_KEY=minioadmin

# Valkey (Docker internal hostname: valkey)
NLP_PIPELINE_VALKEY_URL=redis://valkey:6379/0

# ── DeepInfra ML API keys ─────────────────────────────────────────────────────
# All FOUR vars below carry the SAME single DeepInfra account key (embedding,
# deep extraction, relevance scoring, unresolved-entity resolution). The same key
# is also used by rag-chat, knowledge-graph and api-gateway under their own names.
# Full var→service map + rotation runbook: infra/gitops/docs/deepinfra-key-rotation.md
# Empty = that adapter falls back to Ollama/local. NEVER commit the real key —
# the value lives only in docker.env (gitignored), copied from worldview-gitops.
# NLP_PIPELINE_EMBEDDING_API_KEY=your-deepinfra-key-here  # pragma: allowlist-secret
# NLP_PIPELINE_EXTRACTION_API_KEY=your-deepinfra-key-here  # pragma: allowlist-secret
# NLP_PIPELINE_RELEVANCE_SCORING_API_KEY=your-deepinfra-key-here  # pragma: allowlist-secret
# NLP_PIPELINE_UNRESOLVED_RESOLUTION_API_KEY=your-deepinfra-key-here  # pragma: allowlist-secret

# Auth
# Skip JWKS fetch in test/dev compose profiles that have no api-gateway container.
NLP_PIPELINE_INTERNAL_JWT_SKIP_VERIFICATION=true

# PLAN-0093 A-1 / F-LIVE-001 — required: the startup_assert helper refuses to start
# when internal_jwt_skip_verification=True AND APP_ENV is unset.
APP_ENV=development

# Chunk-search ANN tuning (BP-717 — partial-HNSW-index accelerated path). Optional:
# the code defaults below are production-correct, so these are OFF by default and
# only needed to tune. chunk_ann_indexed_source_types is a comma-separated list of
# source_type buckets that have a dedicated partial HNSW index (migration 0024) —
# a single such source_type is served by the index in ~20ms instead of the ~19s
# exact scan. It MUST match the partial indexes that exist in the DB; adding a
# value without the matching index silently falls back to the exact path.
# NLP_PIPELINE_CHUNK_ANN_INDEXED_SOURCE_TYPES=sec_edgar
# NLP_PIPELINE_CHUNK_ANN_ACCEL_EF_SEARCH=400

# Hybrid chunk-search latency (R1 SEC-filings re-QA). Optional — code defaults
# are production-correct. When ON (default), the /search/chunks hybrid path runs
# its ANN + BM25 legs CONCURRENTLY on separate read-replica sessions instead of
# serially, and caches query embeddings in Valkey keyed by (model, normalized
# query). Set the flag False only to force the sequential fallback for debugging.
# NLP_PIPELINE_CHUNK_SEARCH_PARALLEL_HYBRID=true
# NLP_PIPELINE_CHUNK_EMBED_CACHE_TTL_S=3600

# BP-719 Mode B: cap the words fed to Block-10 deep extraction so the ML phase
# fits the 900s Kafka message watchdog on very large filings (20-48k-word
# 10-Q/10-K). The full document is still chunked + embedded + indexed regardless
# (searchable-first write), so this only bounds KG-relation extraction, which is
# backfillable. 0 (default) disables the cap. Recommended production value: 30000.
# NLP_PIPELINE_DEEP_EXTRACTION_MAX_WORDS=30000
