# GENERATED from worldview-gitops/env/dev/nlp-pipeline.env — DO NOT EDIT; run scripts/setup-dev.sh after editing the gitops source.
# env/dev/nlp-pipeline.env — S6 NLP Pipeline Service (Docker Compose dev)
# Includes ALL configurable settings so any parameter can be tuned without code changes.
# worldview-gitops is PRIVATE — secrets are safe here.
# Copy to ../worldview/services/nlp-pipeline/configs/docker.env via scripts/setup-dev.sh

NLP_PIPELINE_HOST=0.0.0.0
NLP_PIPELINE_PORT=8006
NLP_PIPELINE_DEBUG=false

# nlp_db — S6-owned, Alembic enabled for this DB
NLP_PIPELINE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/nlp_db
NLP_PIPELINE_DATABASE_URL_READ=

# intelligence_db — shared with S7; ALEMBIC_ENABLED MUST stay false (DDL owned by intelligence-migrations)
NLP_PIPELINE_INTELLIGENCE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intelligence_db
NLP_PIPELINE_INTELLIGENCE_DATABASE_URL_READ=
NLP_PIPELINE_ALEMBIC_ENABLED=false

# Kafka
NLP_PIPELINE_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
NLP_PIPELINE_SCHEMA_REGISTRY_URL=http://schema-registry:8081
NLP_PIPELINE_KAFKA_CONSUMER_GROUP=nlp-pipeline-group
NLP_PIPELINE_KAFKA_WATCHLIST_CONSUMER_GROUP=nlp-watchlist-group
NLP_PIPELINE_KAFKA_ENTITY_REFRESH_CONSUMER_GROUP=nlp-entity-refresh-group

# Static group membership (KIP-345) — PLAN-0113 FR-8 / GAP-1.
# These are the AUTHORITATIVE dev defaults for the per-consumer group.instance.id.
# They are intentionally EMPTY here: a single shared value would FENCE the second
# article member (FencedInstanceIdException), so per-replica distinctness lives in
# each service's docker-compose `environment:` block (e.g. article-consumer-0 /
# article-consumer-1), which always wins over this empty env_file default.
# Setting any of these to a non-empty value would apply the SAME id to every
# replica that reads this file — only do so when running a single replica.
NLP_PIPELINE_KAFKA_CONSUMER_INSTANCE_ID=
NLP_PIPELINE_KAFKA_WATCHLIST_CONSUMER_INSTANCE_ID=
NLP_PIPELINE_KAFKA_ENTITY_REFRESH_CONSUMER_INSTANCE_ID=
NLP_PIPELINE_KAFKA_DOCUMENT_DELETION_CONSUMER_INSTANCE_ID=

# Topics consumed
NLP_PIPELINE_TOPIC_ARTICLE_STORED=content.article.stored.v1
NLP_PIPELINE_TOPIC_WATCHLIST_UPDATED=portfolio.watchlist.updated.v1
NLP_PIPELINE_TOPIC_ENTITY_REFRESH=entity.refresh.v1

# Topics produced
NLP_PIPELINE_TOPIC_ARTICLE_ENRICHED=nlp.article.enriched.v1
NLP_PIPELINE_TOPIC_SIGNAL_DETECTED=nlp.signal.detected.v1
NLP_PIPELINE_KAFKA_TOPIC_PROVISIONAL_QUEUED=entity.provisional.queued.v1

# Storage (MinIO dev defaults)
NLP_PIPELINE_STORAGE_ENDPOINT=http://minio:9000
NLP_PIPELINE_STORAGE_ACCESS_KEY=minioadmin
NLP_PIPELINE_STORAGE_SECRET_KEY=minioadmin
NLP_PIPELINE_CHUNK_BUCKET=worldview
NLP_PIPELINE_SILVER_BUCKET=worldview-silver

# Valkey
NLP_PIPELINE_VALKEY_URL=redis://valkey:6379/0

# Ollama — local models (served by the ollama container)
NLP_PIPELINE_OLLAMA_BASE_URL=http://ollama:11434
NLP_PIPELINE_NER_MODEL_ID=urchade/gliner_large-v2.1

# Embedding provider — controls BOTH article ingestion (consumer) and query-time (embed API endpoint).
# Both must use the same provider/model so chunk embeddings and query embeddings are in the same vector space.
# "ollama"    → local bge-large (default; no key needed, ~7-13s on CPU)
# "deepinfra" → BAAI/bge-large-en-v1.5 on DeepInfra GPU (~50-150ms; set EMBEDDING_API_KEY)
# "jina"      → jina-embeddings-v3 on Jina AI REST API (~100-300ms; set JINA_API_KEY)
NLP_PIPELINE_EMBEDDING_PROVIDER=deepinfra
NLP_PIPELINE_EMBEDDING_MODEL_ID=bge-large
# DeepInfra embedding (provider=deepinfra) — reuses the same key as EXTRACTION_API_KEY
NLP_PIPELINE_EMBEDDING_API_KEY=K2wVkx3Uedlcbw6D9WDHZIpM7rI3GG6i
NLP_PIPELINE_EMBEDDING_API_BASE_URL=https://api.deepinfra.com/v1/openai
NLP_PIPELINE_EMBEDDING_API_MODEL_ID=BAAI/bge-large-en-v1.5
# Jina AI embedding (provider=jina)
NLP_PIPELINE_JINA_API_KEY=

# Deep extraction: qwen2.5:7b-instruct is too large for CPU self-hosting.
# Use DeepInfra API (GPU-hosted) instead. extraction_model_id is the Ollama fallback name.
NLP_PIPELINE_EXTRACTION_MODEL_ID=qwen2.5:7b-instruct
NLP_PIPELINE_EXTRACTION_API_KEY=K2wVkx3Uedlcbw6D9WDHZIpM7rI3GG6i
NLP_PIPELINE_EXTRACTION_API_BASE_URL=https://api.deepinfra.com/v1/openai
# Extraction model: gpt-oss-120b@medium — validated 2026-06-16 (worldview repo
# docs/audits/2026-06-16-extraction-model-ab-results.md): beats Qwen3-235B on precision/adherence/
# fabrication, ties recall, ~6x faster under production concurrency, ~10x cheaper. Fallback gpt-oss-20b@low
# on 429/timeout. BOTH are REASONING models — reasoning_effort MUST be set explicitly or they emit empty
# content (max_tokens=8192 is headroom; at @medium the model uses ~1-3k). Binary classifiers
# (relevance scoring, entity resolution) stay on Qwen3.5-9B (simpler task, reasoning model is a bad fit).
NLP_PIPELINE_EXTRACTION_API_MODEL_ID=openai/gpt-oss-120b
NLP_PIPELINE_EXTRACTION_FALLBACK_MODEL_ID=openai/gpt-oss-20b
NLP_PIPELINE_EXTRACTION_REASONING_EFFORT=medium
NLP_PIPELINE_EXTRACTION_FALLBACK_REASONING_EFFORT=low
NLP_PIPELINE_EXTRACTION_MAX_TOKENS=8192
NLP_PIPELINE_EXTRACTION_TIMEOUT_S=300
# 3 attempts (1 initial + 2 retries) on transient failures (429 engine_overloaded /
# 5xx / timeout). gpt-oss-120b's failures are dominantly fast-fail 429s, which fit in
# the 320s total budget; the adapter's budget-guard still caps slow-retry so the 720s
# watchdog is safe. Raised from the default 2 (2026-06-20, ~29% api_error under load).
NLP_PIPELINE_EXTRACTION_MAX_ATTEMPTS=3
# ENHANCEMENT #6: enable the cheap Qwen3-235B co-mention entailment check (drops
# relations whose evidence merely co-mentions subject+object on the 5 high-risk
# predicates). Validated 0% false-positive on high-risk preds, ~$0.0001/article.
NLP_PIPELINE_RELATION_ENTAILMENT_CHECK_ENABLED=true

# GLiNER — containerised NER server (empty = fall back to in-process GLiNER)
NLP_PIPELINE_GLINER_BASE_URL=http://gliner-server:8080
NLP_PIPELINE_GLINER_THRESHOLD=0.35
NLP_PIPELINE_GLINER_RESOLUTION_THRESHOLD=0.45
NLP_PIPELINE_GLINER_BATCH_SIZE=32
NLP_PIPELINE_GLINER_SECTION_TOKEN_LIMIT=450
NLP_PIPELINE_GLINER_NMS_IOU_THRESHOLD=0.5

# Routing tier thresholds (PRD §6.7 Block 5)
# DEEP threshold lowered from 0.70 → 0.45: typical eodhd/finnhub news peaks at 0.59;
# 0.70 was unreachable and prevented any LLM deep-extraction from running in the KG.
NLP_PIPELINE_ROUTING_TIER_DEEP=0.45
NLP_PIPELINE_ROUTING_TIER_MEDIUM=0.35
NLP_PIPELINE_ROUTING_TIER_LIGHT=0.20

# Entity resolution thresholds (PRD §6.7 Block 9)
NLP_PIPELINE_ENTITY_RESOLUTION_AUTO_RESOLVE_THRESHOLD=0.72
NLP_PIPELINE_ENTITY_RESOLUTION_PROVISIONAL_THRESHOLD=0.45

# Novelty gate thresholds (PRD §6.7 Block 8)
NLP_PIPELINE_NOVELTY_MINHASH_THRESHOLD=0.80
NLP_PIPELINE_NOVELTY_EMBEDDING_THRESHOLD=0.90

# Embedding tuning
NLP_PIPELINE_EMBEDDING_BATCH_SIZE=64
# BP-121: bge-large GGML BERT runner aborts under concurrent requests.
# Set max_concurrent=1 to serialize embedding calls and prevent Ollama crashes.
NLP_PIPELINE_EMBEDDING_MAX_CONCURRENT=1
NLP_PIPELINE_EMBEDDING_INSTRUCTION_PREFIX=Represent this financial document passage for retrieval:
NLP_PIPELINE_EMBEDDING_CHUNK_SIZE_NEWS=280
NLP_PIPELINE_EMBEDDING_CHUNK_SIZE_FILINGS=325
NLP_PIPELINE_EMBEDDING_CHUNK_SIZE_EARNINGS=300
NLP_PIPELINE_EMBEDDING_CHUNK_OVERLAP_TOKENS=64

# Deep extraction tuning
NLP_PIPELINE_EXTRACTION_SINGLE_WINDOW_TOKENS=24000
NLP_PIPELINE_EXTRACTION_WINDOW_SIZE_TOKENS=6000
NLP_PIPELINE_EXTRACTION_WINDOW_OVERLAP_TOKENS=500

# Backpressure
NLP_PIPELINE_MAX_OLLAMA_QUEUE_DEPTH=20
NLP_PIPELINE_RESUME_OLLAMA_QUEUE_DEPTH=10

# Dispatcher
NLP_PIPELINE_DISPATCHER_POLL_INTERVAL_SECS=1.0
NLP_PIPELINE_DISPATCHER_BATCH_SIZE=50

# ArticleRelevanceScoringWorker (PRD-0026 Flow B)
NLP_PIPELINE_RELEVANCE_SCORING_CYCLE_SECONDS=1800
NLP_PIPELINE_RELEVANCE_SCORING_BATCH_SIZE=50
NLP_PIPELINE_RELEVANCE_SCORING_OLLAMA_URL=http://ollama:11434
NLP_PIPELINE_RELEVANCE_SCORING_MODEL=qwen3:0.6b
NLP_PIPELINE_RELEVANCE_SCORING_TIMEOUT_SECONDS=30
# DeepInfra provider for relevance scoring (~100-200ms GPU vs 2-5s CPU Ollama)
# Model options (availability depends on DeepInfra account tier):
#   meta-llama/Meta-Llama-3.1-8B-Instruct  (confirmed available, ~100-200ms)
#   Qwen/Qwen2.5-0.5B-Instruct             (smaller, faster — upgrade account to unlock)
#   Qwen/Qwen2.5-1.5B-Instruct             (medium — upgrade account to unlock)
NLP_PIPELINE_RELEVANCE_SCORING_API_KEY=K2wVkx3Uedlcbw6D9WDHZIpM7rI3GG6i
NLP_PIPELINE_RELEVANCE_SCORING_API_BASE_URL=https://api.deepinfra.com/v1/openai
NLP_PIPELINE_RELEVANCE_SCORING_API_MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# Display relevance score weights (must sum to 1.0)
NLP_PIPELINE_S6_DISPLAY_WEIGHT_MARKET=0.50
NLP_PIPELINE_S6_DISPLAY_WEIGHT_LLM=0.40
NLP_PIPELINE_S6_DISPLAY_WEIGHT_ROUTING=0.10

# Price-impact labelling windows (% caps per window)
NLP_PIPELINE_PRICE_IMPACT_CAP_DAY_T0_PCT=5.0
NLP_PIPELINE_PRICE_IMPACT_CAP_DAY_T1_PCT=5.0
NLP_PIPELINE_PRICE_IMPACT_CAP_DAY_T2_PCT=7.5
NLP_PIPELINE_PRICE_IMPACT_CAP_DAY_T5_PCT=10.0
NLP_PIPELINE_PRICE_IMPACT_CYCLE_SECONDS=14400
NLP_PIPELINE_PRICE_IMPACT_MIN_AGE_HOURS=25
NLP_PIPELINE_MARKET_DATA_INTERNAL_URL=http://market-data:8003

# UnresolvedResolutionWorker (PLAN-0033)
NLP_PIPELINE_UNRESOLVED_RESOLUTION_ENABLED=true
NLP_PIPELINE_UNRESOLVED_RESOLUTION_INTERVAL_S=1800
NLP_PIPELINE_UNRESOLVED_RESOLUTION_BATCH_SIZE=500
NLP_PIPELINE_UNRESOLVED_RESOLUTION_LOOKBACK_DAYS=90
NLP_PIPELINE_UNRESOLVED_RESOLUTION_OLLAMA_BASE_URL=http://ollama:11434
NLP_PIPELINE_UNRESOLVED_RESOLUTION_CLASSIFICATION_MODEL=qwen3:0.6b
NLP_PIPELINE_UNRESOLVED_RESOLUTION_MAX_LLM_BATCH=20
# BP-231 variant: qwen3:0.6b on CPU takes 5-10s; 10s default causes frequent timeouts.
# Set to 30s to match relevance-scoring worker and allow full inference completion.
NLP_PIPELINE_UNRESOLVED_RESOLUTION_LLM_TIMEOUT_S=30
# DeepInfra provider for entity classification (~100-200ms GPU vs 2-5s CPU Ollama)
# Model options (availability depends on DeepInfra account tier):
#   meta-llama/Meta-Llama-3.1-8B-Instruct  (confirmed available, ~100-200ms)
#   Qwen/Qwen2.5-0.5B-Instruct             (smaller, faster — upgrade account to unlock)
#   Qwen/Qwen2.5-1.5B-Instruct             (medium — upgrade account to unlock)
NLP_PIPELINE_UNRESOLVED_RESOLUTION_API_KEY=K2wVkx3Uedlcbw6D9WDHZIpM7rI3GG6i
NLP_PIPELINE_UNRESOLVED_RESOLUTION_API_BASE_URL=https://api.deepinfra.com/v1/openai
NLP_PIPELINE_UNRESOLVED_RESOLUTION_API_MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo

# LLM replay worker (PLAN-0055 Sub-Plan C-4) — batches articles when admin triggers
# POST /api/v1/admin/llm-replay; reuses worker idempotency keyed on (model_id, prompt_version).
NLP_LLM_REPLAY_BATCH_SIZE=50

# Auth
NLP_PIPELINE_API_GATEWAY_URL=http://api-gateway:8000
NLP_PIPELINE_ADMIN_TOKEN=test-admin-token
NLP_PIPELINE_INTERNAL_JWT_SKIP_VERIFICATION=true

# Observability
NLP_PIPELINE_LOG_LEVEL=INFO
NLP_PIPELINE_LOG_JSON=true
NLP_PIPELINE_OTLP_ENDPOINT=
