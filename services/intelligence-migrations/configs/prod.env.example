# intelligence-migrations — Production Environment (fill in actual values)
# This is a one-shot init container (restart: "no") that runs Alembic migrations
# for intelligence_db and populates embedding seed data.
# In docker-compose.prod.yml these vars are passed via environment: (not env_file:).
# Document production values here so worldview-gitops/setup-prod.sh can inject them.

# Intelligence DB (intelligence_db — shared by S6 nlp-pipeline and S7 knowledge-graph)
# Format: postgresql://user:password@host:port/dbname
# Internal Docker hostname: postgres
INTELLIGENCE_DB_URL=postgresql://postgres:<POSTGRES_PASSWORD>@postgres:5432/intelligence_db

# Embedding base URL for populate_embeddings.py seed script
# In production with DeepInfra externalized this can be left at default (Ollama fallback).
# Set to DeepInfra base URL if running populate step via DeepInfra.
EMBEDDING_BASE_URL=http://ollama:11434

# Embedding model for seed data (must match what nlp-pipeline uses for queries)
EMBEDDING_MODEL=bge-large-en-v1.5
