# market-ingestion — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile runtime).
# Infrastructure hostnames resolve to Docker service names, not localhost.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

MARKET_INGESTION_HOST=0.0.0.0
MARKET_INGESTION_PORT=8002
MARKET_INGESTION_DEBUG=false

# Database (Docker internal hostname: postgres)
MARKET_INGESTION_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ingestion_db

# Kafka (Docker internal listener: kafka:29092)
MARKET_INGESTION_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
MARKET_INGESTION_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Storage (MinIO — Docker internal: minio:9000)
MARKET_INGESTION_STORAGE_ENDPOINT=http://minio:9000
MARKET_INGESTION_STORAGE_ACCESS_KEY=minioadmin
MARKET_INGESTION_STORAGE_SECRET_KEY=minioadmin

# Valkey (Docker internal hostname: valkey)
MARKET_INGESTION_VALKEY_URL=redis://valkey:6379/0
