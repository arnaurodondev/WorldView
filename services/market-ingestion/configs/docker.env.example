# market-ingestion — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile runtime).
# Infrastructure hostnames resolve to Docker service names, not localhost.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

# ── Server ──────────────────────────────────────────────────────────────────
MARKET_INGESTION_HOST=0.0.0.0
MARKET_INGESTION_PORT=8002
MARKET_INGESTION_DEBUG=false

# ── Database (Docker internal hostname: postgres) ─────────────────────────────
MARKET_INGESTION_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/ingestion_db
MARKET_INGESTION_DATABASE_URL_READ=

# ── Kafka (Docker internal listener: kafka:29092) ─────────────────────────────
MARKET_INGESTION_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
MARKET_INGESTION_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# ── Storage (MinIO — Docker internal: minio:9000) ─────────────────────────────
MARKET_INGESTION_STORAGE_ENDPOINT=http://minio:9000
# Dev default — replace with real credentials for production (never commit real credentials)
MARKET_INGESTION_STORAGE_ACCESS_KEY=minioadmin
MARKET_INGESTION_STORAGE_SECRET_KEY=minioadmin
MARKET_INGESTION_STORAGE_BUCKET=market-ingestion
MARKET_INGESTION_BRONZE_BUCKET=market-bronze
MARKET_INGESTION_CANONICAL_BUCKET=market-canonical

# ── Provider API Keys ─────────────────────────────────────────────────────────
# Replace 'demo' with your real EODHD API key for production
MARKET_INGESTION_EODHD_API_KEY=demo
MARKET_INGESTION_FINNHUB_API_KEY=
MARKET_INGESTION_POLYGON_API_KEY=
MARKET_INGESTION_ALPHA_VANTAGE_API_KEY=

# ── Valkey (Docker internal hostname: valkey) ─────────────────────────────────
MARKET_INGESTION_VALKEY_URL=redis://valkey:6379/0

# ── Scheduler ─────────────────────────────────────────────────────────────────
MARKET_INGESTION_SCHEDULER_TICK_INTERVAL_SECONDS=60.0
MARKET_INGESTION_SCHEDULER_MAX_TASKS_PER_TICK=1000

# ── Worker ────────────────────────────────────────────────────────────────────
MARKET_INGESTION_WORKER_BATCH_SIZE=10
MARKET_INGESTION_WORKER_LEASE_SECONDS=300
MARKET_INGESTION_WORKER_CONCURRENCY=4

# ── Dispatcher ────────────────────────────────────────────────────────────────
MARKET_INGESTION_DISPATCHER_BATCH_SIZE=50
MARKET_INGESTION_DISPATCHER_POLL_INTERVAL_SECONDS=1.0
MARKET_INGESTION_DISPATCHER_MAX_ATTEMPTS=5

# ── Internal service-to-service auth (QA-018) ────────────────────────────────
# Required: protects POST /trigger and POST /backfill from unauthenticated calls.
# Generate with: openssl rand -hex 32
MARKET_INGESTION_INTERNAL_SERVICE_TOKEN=

# ── Observability ─────────────────────────────────────────────────────────────
MARKET_INGESTION_OTLP_ENDPOINT=
MARKET_INGESTION_LOG_LEVEL=INFO
