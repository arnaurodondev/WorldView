# api-gateway — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile runtime).
# Infrastructure hostnames resolve to Docker service names, not localhost.
# Upstream services are addressed by their Compose service names.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_DEBUG=false

# Database (Docker internal hostname: postgres)
API_GATEWAY_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/gateway_db

# Kafka (Docker internal listener: kafka:29092)
API_GATEWAY_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
API_GATEWAY_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Storage (MinIO — Docker internal: minio:9000)
API_GATEWAY_STORAGE_ENDPOINT=http://minio:9000
# Dev default — replace with real credentials for production (never commit real credentials)
API_GATEWAY_STORAGE_ACCESS_KEY=minioadmin
API_GATEWAY_STORAGE_SECRET_KEY=minioadmin

# Valkey (Docker internal hostname: valkey)
API_GATEWAY_VALKEY_URL=redis://valkey:6379/0

# ── DeepInfra ML API key ──────────────────────────────────────────────────────
# Powers the NL screener's direct chat/completions call. Carries the SAME single
# DeepInfra account key also used by rag-chat, nlp-pipeline and knowledge-graph
# under their own names. Full map + rotation runbook:
#   infra/gitops/docs/deepinfra-key-rotation.md
# NEVER commit the real key — it lives only in docker.env (gitignored), copied
# from worldview-gitops.
# API_GATEWAY_DEEPINFRA_API_KEY=your-deepinfra-key-here  # pragma: allowlist-secret

# Upstream service URLs (Docker Compose service names)
API_GATEWAY_PORTFOLIO_URL=http://svc-portfolio:8001
API_GATEWAY_MARKET_INGESTION_URL=http://svc-market-ingestion:8002
API_GATEWAY_MARKET_DATA_URL=http://svc-market-data:8003
API_GATEWAY_CONTENT_INGESTION_URL=http://svc-content-ingestion:8004
API_GATEWAY_CONTENT_STORE_URL=http://svc-content-store:8005
API_GATEWAY_NLP_PIPELINE_URL=http://svc-nlp-pipeline:8006
API_GATEWAY_KNOWLEDGE_GRAPH_URL=http://svc-knowledge-graph:8007
API_GATEWAY_RAG_CHAT_URL=http://svc-rag-chat:8008

# Observability
API_GATEWAY_LOG_LEVEL=INFO
API_GATEWAY_LOG_JSON=true
API_GATEWAY_OTLP_ENDPOINT=http://alloy:4317

# PLAN-0093 A-1 / F-LIVE-001 — required: the startup_assert helper refuses to start
# when internal_jwt_skip_verification=True AND APP_ENV is unset.
APP_ENV=development
