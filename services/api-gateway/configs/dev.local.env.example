# api-gateway — Local Development Environment
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_DEBUG=true

# Valkey (caching + rate limiting)
API_GATEWAY_VALKEY_URL=redis://localhost:6379/0

# OIDC — Zitadel Cloud (required; service fails to start without these)
API_GATEWAY_OIDC_ISSUER_URL=https://<your-instance>.zitadel.cloud
API_GATEWAY_OIDC_CLIENT_ID=<your-client-id>
API_GATEWAY_OIDC_CLIENT_SECRET=<your-client-secret>
API_GATEWAY_OIDC_AUDIENCE=<your-client-id>

# Internal JWT RS256 keypair (generate with: openssl genrsa -out s9.key 2048 && openssl rsa -in s9.key -pubout -out s9.pub)
# Set these to the PEM contents with literal \n between lines (single-line env var format)
API_GATEWAY_INTERNAL_JWT_PRIVATE_KEY=<paste_rsa2048_private_pem_here>
API_GATEWAY_INTERNAL_JWT_PUBLIC_KEY=<paste_rsa2048_public_pem_here>

# Frontend
API_GATEWAY_FRONTEND_URL=http://localhost:5173
API_GATEWAY_COOKIE_SECURE=false

# CORS
API_GATEWAY_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Downstream service URLs (defaults match docker-compose)
API_GATEWAY_PORTFOLIO_URL=http://localhost:8001
API_GATEWAY_MARKET_INGESTION_URL=http://localhost:8002
API_GATEWAY_MARKET_DATA_URL=http://localhost:8003
API_GATEWAY_CONTENT_INGESTION_URL=http://localhost:8004
API_GATEWAY_CONTENT_STORE_URL=http://localhost:8005
API_GATEWAY_NLP_PIPELINE_URL=http://localhost:8006
API_GATEWAY_KNOWLEDGE_GRAPH_URL=http://localhost:8007
API_GATEWAY_RAG_CHAT_URL=http://localhost:8008
API_GATEWAY_ALERT_URL=http://localhost:8010

# Rate limiting
API_GATEWAY_RATE_LIMIT_REQUESTS=1000
API_GATEWAY_RATE_LIMIT_WINDOW_SECONDS=60

# PLAN-0057 Wave A-1 / BP-303 — Service-account secret for
# POST /internal/v1/service-token. Background workers (e.g. nlp-pipeline
# price-impact worker) authenticate via this shared secret to mint an
# RS256 internal JWT. Leave empty in local dev (workers fall back to
# /v1/auth/dev-login). In production, MUST be set via sealed secret.
API_GATEWAY_SERVICE_ACCOUNT_TOKEN=

# Observability
API_GATEWAY_SERVICE_NAME=api-gateway
API_GATEWAY_LOG_LEVEL=INFO
API_GATEWAY_LOG_JSON=false
API_GATEWAY_OTLP_ENDPOINT=
