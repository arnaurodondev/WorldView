# content-store — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile runtime).
# Infrastructure hostnames resolve to Docker service names, not localhost.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

CONTENT_STORE_HOST=0.0.0.0
CONTENT_STORE_PORT=8005
CONTENT_STORE_DEBUG=false

# Database (Docker internal hostname: postgres)
CONTENT_STORE_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/content_store_db

# Kafka (Docker internal listener: kafka:29092)
CONTENT_STORE_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
CONTENT_STORE_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Storage (MinIO — Docker internal: minio:9000)
CONTENT_STORE_STORAGE_ENDPOINT=http://minio:9000
CONTENT_STORE_STORAGE_ACCESS_KEY=minioadmin
CONTENT_STORE_STORAGE_SECRET_KEY=minioadmin

# Valkey (Docker internal hostname: valkey)
CONTENT_STORE_VALKEY_URL=redis://valkey:6379/0

# Observability
CONTENT_STORE_LOG_LEVEL=INFO
CONTENT_STORE_LOG_JSON=true
CONTENT_STORE_OTLP_ENDPOINT=http://alloy:4317
