# portfolio — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile runtime).
# Infrastructure hostnames resolve to Docker service names, not localhost.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

PORTFOLIO_SERVICE_NAME=portfolio
PORTFOLIO_HOST=0.0.0.0
PORTFOLIO_PORT=8001
PORTFOLIO_DEBUG=false

# Database (Docker internal hostname: postgres)
PORTFOLIO_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/portfolio_db

# Kafka (Docker internal listener: kafka:29092)
PORTFOLIO_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
PORTFOLIO_SCHEMA_REGISTRY_URL=http://schema-registry:8081
PORTFOLIO_KAFKA_SCHEMA_REGISTRY_BASIC_AUTH=
PORTFOLIO_KAFKA_AUTO_REGISTER_SCHEMAS=true

# Kafka topics (produced)
PORTFOLIO_TOPIC_PORTFOLIO_EVENTS=portfolio.events.v1

# Kafka topics (consumed)
PORTFOLIO_TOPIC_INSTRUMENT_CREATED=market.instrument.created
PORTFOLIO_TOPIC_INSTRUMENT_UPDATED=market.instrument.updated
PORTFOLIO_CONSUMER_GROUP_INSTRUMENT=portfolio-instrument-sync

# Outbox dispatcher
PORTFOLIO_DISPATCHER_IMMEDIATE_BATCH_SIZE=100
PORTFOLIO_DISPATCHER_POLL_INTERVAL_SECONDS=5.0
PORTFOLIO_DISPATCHER_LEASE_SECONDS=30
PORTFOLIO_DISPATCHER_MAX_ATTEMPTS=10
PORTFOLIO_DISPATCHER_BACKOFF_BASE_SECONDS=1.0

# Storage (MinIO — Docker internal: minio:9000)
PORTFOLIO_STORAGE_ENDPOINT=http://minio:9000
PORTFOLIO_STORAGE_ACCESS_KEY=minioadmin
PORTFOLIO_STORAGE_SECRET_KEY=minioadmin

# Valkey (Docker internal hostname: valkey)
PORTFOLIO_VALKEY_URL=redis://valkey:6379/0

# Observability
PORTFOLIO_LOG_LEVEL=INFO
PORTFOLIO_LOG_FORMAT=json
PORTFOLIO_OTLP_ENDPOINT=
