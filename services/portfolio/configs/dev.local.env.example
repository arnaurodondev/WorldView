# portfolio — Local Development Environment
PORTFOLIO_SERVICE_NAME=portfolio
PORTFOLIO_HOST=0.0.0.0
PORTFOLIO_PORT=8001
PORTFOLIO_DEBUG=true

# Database
PORTFOLIO_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/portfolio_db

# Kafka
PORTFOLIO_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
PORTFOLIO_KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081
PORTFOLIO_KAFKA_SCHEMA_REGISTRY_BASIC_AUTH=
PORTFOLIO_KAFKA_AUTO_REGISTER_SCHEMAS=true

# Kafka topics (produced)
PORTFOLIO_TOPIC_PORTFOLIO_EVENTS=portfolio.events.v1

# Kafka topics (consumed)
PORTFOLIO_TOPIC_INSTRUMENT_CREATED=market.instrument.created
PORTFOLIO_TOPIC_INSTRUMENT_UPDATED=market.instrument.updated
PORTFOLIO_CONSUMER_GROUP_INSTRUMENT=portfolio-instrument-sync

# Outbox dispatcher
PORTFOLIO_DISPATCHER_IMMEDIATE_BATCH_SIZE=100
PORTFOLIO_DISPATCHER_POLL_INTERVAL_SECONDS=5.0
PORTFOLIO_DISPATCHER_LEASE_SECONDS=30
PORTFOLIO_DISPATCHER_MAX_ATTEMPTS=10
PORTFOLIO_DISPATCHER_BACKOFF_BASE_SECONDS=1.0

# Storage (MinIO for local dev)
PORTFOLIO_STORAGE_ENDPOINT=http://localhost:7480
PORTFOLIO_STORAGE_ACCESS_KEY=minioadmin
PORTFOLIO_STORAGE_SECRET_KEY=minioadmin

# Valkey
PORTFOLIO_VALKEY_URL=redis://localhost:6379/0

# Observability
PORTFOLIO_LOG_LEVEL=DEBUG
PORTFOLIO_LOG_FORMAT=console
PORTFOLIO_OTLP_ENDPOINT=
