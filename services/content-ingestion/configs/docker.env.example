# content-ingestion — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile runtime).
# Infrastructure hostnames resolve to Docker service names, not localhost.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

CONTENT_INGESTION_HOST=0.0.0.0
CONTENT_INGESTION_PORT=8004
CONTENT_INGESTION_DEBUG=false

# Database (Docker internal hostname: postgres)
CONTENT_INGESTION_DB_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/content_ingestion_db

# Kafka (Docker internal listener: kafka:29092)
CONTENT_INGESTION_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
CONTENT_INGESTION_KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Storage (MinIO — Docker internal: minio:9000)
CONTENT_INGESTION_MINIO_ENDPOINT=minio:9000
# Dev default — replace with real credentials for production (never commit real credentials)
CONTENT_INGESTION_MINIO_ACCESS_KEY=minioadmin
CONTENT_INGESTION_MINIO_SECRET_KEY=minioadmin

# Valkey (Docker internal hostname: valkey)
CONTENT_INGESTION_VALKEY_URL=redis://valkey:6379/0

# Observability
CONTENT_INGESTION_LOG_LEVEL=INFO
CONTENT_INGESTION_LOG_JSON=true
CONTENT_INGESTION_OTLP_ENDPOINT=http://alloy:4317

# Auth
# Skip JWKS fetch in test/dev compose profiles that have no api-gateway container.
CONTENT_INGESTION_INTERNAL_JWT_SKIP_VERIFICATION=true

# PLAN-0093 A-1 / F-LIVE-001 — required: the startup_assert helper refuses to start
# when internal_jwt_skip_verification=True AND APP_ENV is unset.
APP_ENV=development
