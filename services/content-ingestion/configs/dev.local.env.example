# content-ingestion — Local Development Environment
CONTENT_INGESTION_HOST=0.0.0.0
CONTENT_INGESTION_PORT=8004
CONTENT_INGESTION_DEBUG=true
CONTENT_INGESTION_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/content_ingestion_db
CONTENT_INGESTION_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
CONTENT_INGESTION_SCHEMA_REGISTRY_URL=http://localhost:8081
CONTENT_INGESTION_STORAGE_ENDPOINT=http://localhost:7480
CONTENT_INGESTION_STORAGE_ACCESS_KEY=minioadmin
CONTENT_INGESTION_STORAGE_SECRET_KEY=minioadmin
CONTENT_INGESTION_VALKEY_URL=redis://localhost:6379/0

# Authentication
# CONTENT_INGESTION_ADMIN_TOKEN — admin-only operations (source CRUD, DLQ, status)
CONTENT_INGESTION_ADMIN_TOKEN=dev-admin-token
# Internal JWT auth (PRD-0025): InternalJWTMiddleware fetches JWKS from S9
CONTENT_INGESTION_API_GATEWAY_URL=http://localhost:8000

# SEC EDGAR market-hours polling intervals (optional — defaults to 60s/1800s)
# CONTENT_INGESTION_SEC_EDGAR__MARKET_HOURS_INTERVAL_SECONDS=60
# CONTENT_INGESTION_SEC_EDGAR__OFF_HOURS_INTERVAL_SECONDS=1800
# Bounded-backfill cap: max NEW filings whose manifest+document are fetched per
# cycle. Keeps a single SEC task inside the worker task-timeout (fix for the
# reclaim loop). Already-stored filings are skipped cheaply and do not count.
# Default 25; raise to drain a large historical backfill faster.
# CONTENT_INGESTION_SEC_EDGAR__MAX_FILINGS_PER_CYCLE=25

# Polymarket Gamma API (optional — defaults shown)
# CONTENT_INGESTION_POLYMARKET__BASE_URL=https://gamma-api.polymarket.com/markets
# CONTENT_INGESTION_POLYMARKET__PAGE_SIZE=500
# CONTENT_INGESTION_POLYMARKET__MAX_PAGES_PER_CYCLE=20
