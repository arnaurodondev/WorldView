# knowledge-graph — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile runtime).
# Infrastructure hostnames resolve to Docker service names, not localhost.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

KNOWLEDGE_GRAPH_HOST=0.0.0.0
KNOWLEDGE_GRAPH_PORT=8007
KNOWLEDGE_GRAPH_DEBUG=false

# Database (Docker internal hostname: postgres)
KNOWLEDGE_GRAPH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intelligence_db
KNOWLEDGE_GRAPH_ALEMBIC_ENABLED=false

# Kafka (Docker internal listener: kafka:29092)
KNOWLEDGE_GRAPH_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KNOWLEDGE_GRAPH_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Storage (MinIO — Docker internal: minio:9000)
KNOWLEDGE_GRAPH_STORAGE_ENDPOINT=http://minio:9000
KNOWLEDGE_GRAPH_STORAGE_ACCESS_KEY=minioadmin
KNOWLEDGE_GRAPH_STORAGE_SECRET_KEY=minioadmin

# Valkey (Docker internal hostname: valkey)
KNOWLEDGE_GRAPH_VALKEY_URL=redis://valkey:6379/0
