# GENERATED from worldview-gitops/env/dev/knowledge-graph.env — DO NOT EDIT; run scripts/setup-dev.sh after editing the gitops source.
# env/dev/knowledge-graph.env — S7 Knowledge Graph Service (Docker Compose dev)
# S7 uses intelligence_db. ALEMBIC_ENABLED MUST stay false (DDL owned by intelligence-migrations).
# worldview-gitops is PRIVATE — secrets are safe here.
# Copy to ../worldview/services/knowledge-graph/configs/docker.env via scripts/setup-dev.sh

KNOWLEDGE_GRAPH_HOST=0.0.0.0
KNOWLEDGE_GRAPH_PORT=8007
KNOWLEDGE_GRAPH_DEBUG=false

# intelligence_db — shared with S6, DDL owned by intelligence-migrations
KNOWLEDGE_GRAPH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/intelligence_db
KNOWLEDGE_GRAPH_DATABASE_URL_READ=
KNOWLEDGE_GRAPH_ALEMBIC_ENABLED=false

# Kafka
KNOWLEDGE_GRAPH_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KNOWLEDGE_GRAPH_KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081
KNOWLEDGE_GRAPH_KAFKA_CONSUMER_GROUP=kg-service-group
KNOWLEDGE_GRAPH_KAFKA_TOPIC_ENRICHED=nlp.article.enriched.v1
KNOWLEDGE_GRAPH_KAFKA_TOPIC_ENTITY_CREATED=entity.canonical.created.v1
KNOWLEDGE_GRAPH_KAFKA_TOPIC_INSTRUMENT_CREATED=market.instrument.created
KNOWLEDGE_GRAPH_KAFKA_TOPIC_DATASET_FETCHED=market.dataset.fetched
KNOWLEDGE_GRAPH_KAFKA_TOPIC_PROVISIONAL_QUEUED=entity.provisional.queued.v1
KNOWLEDGE_GRAPH_KAFKA_CONSUMER_GROUP_PROVISIONAL_QUEUED=kg-provisional-queued-group

# Storage (MinIO dev defaults)
KNOWLEDGE_GRAPH_STORAGE_ENDPOINT=http://minio:9000
KNOWLEDGE_GRAPH_STORAGE_ACCESS_KEY=minioadmin
KNOWLEDGE_GRAPH_STORAGE_SECRET_KEY=minioadmin

# Valkey
KNOWLEDGE_GRAPH_VALKEY_URL=redis://valkey:6379/0

# Ollama — entity embeddings (fallback when EMBEDDING_PROVIDER=ollama)
KNOWLEDGE_GRAPH_OLLAMA_BASE_URL=http://ollama:11434
# bge-large:latest produces 1024-dim vectors (must match pgvector schema).
# nomic-embed-text produces 768-dim and MUST NOT be used here (dimension mismatch).
KNOWLEDGE_GRAPH_EMBEDDING_MODEL_ID=bge-large:latest

# Embedding provider — controls all entity embedding workers (definition, narrative, fundamentals, etc.)
# IMPORTANT: must use same provider/model as NLP_PIPELINE_EMBEDDING_PROVIDER to stay in same vector space.
# "ollama"    → local bge-large:latest via OllamaEmbeddingAdapter (~7-13s CPU)
# "deepinfra" → BAAI/bge-large-en-v1.5 on DeepInfra GPU (~50-150ms; needs api_key)
KNOWLEDGE_GRAPH_EMBEDDING_PROVIDER=deepinfra
KNOWLEDGE_GRAPH_EMBEDDING_API_KEY=K2wVkx3Uedlcbw6D9WDHZIpM7rI3GG6i
KNOWLEDGE_GRAPH_EMBEDDING_API_BASE_URL=https://api.deepinfra.com/v1/openai
KNOWLEDGE_GRAPH_EMBEDDING_API_MODEL_ID=BAAI/bge-large-en-v1.5

# Upstream service dependencies
KNOWLEDGE_GRAPH_MARKET_DATA_BASE_URL=http://market-data:8003
KNOWLEDGE_GRAPH_EODHD_BASE_URL=https://eodhd.com/api

# LLM description generation — DeepInfra Qwen3 (DEEPINFRA_API_KEY shared with embedding + extraction)
# Primary: Qwen3-235B-A22B-Instruct-2507 (high-quality MoE); fallback: Qwen3-32B
KNOWLEDGE_GRAPH_DESCRIPTION_PROVIDER=deepinfra
KNOWLEDGE_GRAPH_DESCRIPTION_DEEPINFRA_MODEL_ID=Qwen/Qwen3-235B-A22B-Instruct-2507
KNOWLEDGE_GRAPH_DESCRIPTION_DEEPINFRA_FALLBACK_MODEL_ID=Qwen/Qwen3-32B
KNOWLEDGE_GRAPH_DESCRIPTION_DEEPINFRA_CONCURRENCY=4
KNOWLEDGE_GRAPH_DESCRIPTION_MAX_MONTHLY_USD=10.0
KNOWLEDGE_GRAPH_DESCRIPTION_GEMINI_CONCURRENCY=4

# Geographic filter settings
KNOWLEDGE_GRAPH_ECONOMIC_EVENT_COUNTRIES=US,DE,GB,JP,CN,EU
KNOWLEDGE_GRAPH_MACRO_INDICATOR_COUNTRIES=USA,GBR,DEU,JPN,CHN

# Knowledge worker intervals (seconds)
KNOWLEDGE_GRAPH_WORKER_CONFIDENCE_INTERVAL_S=900
KNOWLEDGE_GRAPH_WORKER_CONTRADICTION_INTERVAL_S=1800
KNOWLEDGE_GRAPH_WORKER_SUMMARY_INTERVAL_S=3600
KNOWLEDGE_GRAPH_WORKER_DEFINITION_REFRESH_INTERVAL_S=3600
KNOWLEDGE_GRAPH_WORKER_NARRATIVE_REFRESH_INTERVAL_S=3600
KNOWLEDGE_GRAPH_WORKER_FUNDAMENTALS_REFRESH_INTERVAL_S=7200
KNOWLEDGE_GRAPH_WORKER_EMBEDDING_REFRESH_INTERVAL_S=10800
# Provisional enrichment worker — 5 min catch-up sweep; hot path via entity.provisional.queued.v1 consumer (Wave E)
KNOWLEDGE_GRAPH_WORKER_PROVISIONAL_ENRICHMENT_INTERVAL_S=300
KNOWLEDGE_GRAPH_WORKER_PROVISIONAL_ENRICHMENT_BATCH_SIZE=500
KNOWLEDGE_GRAPH_WORKER_PROVISIONAL_ENRICHMENT_CONCURRENCY=5
KNOWLEDGE_GRAPH_WORKER_PROVISIONAL_ENRICHMENT_MAX_RETRIES=5

# Worker 13J — Structured Enrichment (PLAN-0073)
# Primary: Qwen3-235B-A22B-Instruct-2507 (high-quality MoE, same account key as DESCRIPTION_DEEPINFRA)
# Fallback: Llama-3.1-8B-Instruct-Turbo
# NEVER use Qwen2.5-0.5B or Qwen2.5-1.5B — both return 404 on this account
KNOWLEDGE_GRAPH_ENRICHMENT_LLM_MODEL_ID=Qwen/Qwen3-235B-A22B-Instruct-2507
KNOWLEDGE_GRAPH_ENRICHMENT_LLM_FALLBACK_MODEL_ID=meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
KNOWLEDGE_GRAPH_KAFKA_CONSUMER_GROUP_STRUCTURED_ENRICHMENT=kg-structured-enrichment-group

# DeepInfra extraction — primary extraction slot in FallbackChainClient (PLAN-0061 T-C-2).
# When DEEPINFRA_API_KEY is set, a DeepSeekExtractionAdapter is wired at position 0
# in the extraction chain (DeepInfra GPU → Ollama CPU → Gemini). The key is the same
# account key used for embedding (EMBEDDING_API_KEY above).
# Qwen3-235B-A22B-Instruct-2507: 50% cheaper input ($0.071/M vs $0.14/M) + 64% cheaper output ($0.10/M vs $0.28/M)
# than DeepSeek-V4-Flash; 250k context is ample (KG extraction inputs are <5k tokens).
# Binary classifiers (relevance scoring, entity noise classification) stay on Llama-3.1-8B (cheaper, sufficient).
KNOWLEDGE_GRAPH_DEEPINFRA_EXTRACTION_MODEL_ID=Qwen/Qwen3-235B-A22B-Instruct-2507
KNOWLEDGE_GRAPH_DEEPINFRA_EXTRACTION_BASE_URL=https://api.deepinfra.com/v1/openai
KNOWLEDGE_GRAPH_DEEPINFRA_EXTRACTION_CONCURRENCY=5
# KNOWLEDGE_GRAPH_DEEPINFRA_API_KEY is set below in the Secrets section (same key as EMBEDDING_API_KEY)

# Confidence calibration thresholds
KNOWLEDGE_GRAPH_RELATION_CANONICALIZATION_THRESHOLD=0.35
KNOWLEDGE_GRAPH_CONFIDENCE_CORROBORATION_CAP=0.20
KNOWLEDGE_GRAPH_CONFIDENCE_CONTRADICTION_CAP=0.60
KNOWLEDGE_GRAPH_CONFIDENCE_CORROBORATION_GAIN_PER_SOURCE=0.05
KNOWLEDGE_GRAPH_CONFIDENCE_CORROBORATION_MIN_TEMPORAL_WEIGHT=0.1
KNOWLEDGE_GRAPH_CONFIDENCE_CONTRADICTION_TOP_K=3
# PLAN-0109 W1 — Beta/subjective-logic confidence backbone (v2)
KNOWLEDGE_GRAPH_CONFIDENCE_FORMULA_V2=true
KNOWLEDGE_GRAPH_CONFIDENCE_PRIOR_STRENGTH=2.0
KNOWLEDGE_GRAPH_CONFIDENCE_SIGNAL_DECAY_FLOOR=0.1
KNOWLEDGE_GRAPH_CONFIDENCE_DEFAULT_SOURCE_TRUST=0.5
# PLAN-0109 follow-up — one-time full re-sweep after a confidence-formula change.
# When true the staleness sweep ignores the per-class cadence and recomputes every
# evidence-backed relation, so stale v1 values cannot persist for up to a full
# decay-class cadence (7 days for DURABLE/PERMANENT). Operator runbook: set true +
# restart scheduler, let confidence_worker_complete drain, then set back to false.
KNOWLEDGE_GRAPH_CONFIDENCE_FORCE_FULL_RESWEEP=false

# Feature flags
KNOWLEDGE_GRAPH_CYPHER_ENABLED=true

# Auth
KNOWLEDGE_GRAPH_API_GATEWAY_URL=http://api-gateway:8000
KNOWLEDGE_GRAPH_ADMIN_TOKEN=test-admin-token
KNOWLEDGE_GRAPH_INTERNAL_JWT_SKIP_VERIFICATION=true

# Observability
KNOWLEDGE_GRAPH_LOG_LEVEL=INFO
KNOWLEDGE_GRAPH_LOG_JSON=true
KNOWLEDGE_GRAPH_OTLP_ENDPOINT=

# ── Secrets (fill in before running make dev) ────────────────────────────────
# EODHD — for market data workers in knowledge-graph (https://eodhd.com)
KNOWLEDGE_GRAPH_EODHD_API_KEY=667bca9682f434.24126467
# Gemini (Google AI Studio) — https://aistudio.google.com
# Only needed if KNOWLEDGE_GRAPH_DESCRIPTION_PROVIDER=gemini; set to "none" above by default.
KNOWLEDGE_GRAPH_GEMINI_API_KEY=
# DeepInfra API key — shared between embedding + extraction (same account key).
# Reuses the same key as EMBEDDING_API_KEY above; the env var is named separately
# so the KG scheduler can enable extraction independently from embedding.
KNOWLEDGE_GRAPH_DEEPINFRA_API_KEY=K2wVkx3Uedlcbw6D9WDHZIpM7rI3GG6i
