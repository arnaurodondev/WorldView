# knowledge-graph — Local Development Environment
KNOWLEDGE_GRAPH_HOST=0.0.0.0
KNOWLEDGE_GRAPH_PORT=8007
KNOWLEDGE_GRAPH_DEBUG=true
KNOWLEDGE_GRAPH_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/intelligence_db
KNOWLEDGE_GRAPH_ALEMBIC_ENABLED=false
KNOWLEDGE_GRAPH_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KNOWLEDGE_GRAPH_SCHEMA_REGISTRY_URL=http://localhost:8081
KNOWLEDGE_GRAPH_STORAGE_ENDPOINT=http://localhost:7480
KNOWLEDGE_GRAPH_STORAGE_ACCESS_KEY=minioadmin
KNOWLEDGE_GRAPH_STORAGE_SECRET_KEY=minioadmin
KNOWLEDGE_GRAPH_VALKEY_URL=redis://localhost:6379/0

# Entity description generation (PRD-0017 §6.5, PLAN-0057 Wave E-2)
# "gemini" enables LLM descriptions for non-company entities (sectors, currencies, regulators, …).
# When provider=gemini and API key is empty, the service falls back to template descriptions and logs a warning.
KNOWLEDGE_GRAPH_DESCRIPTION_PROVIDER=gemini
KNOWLEDGE_GRAPH_GEMINI_API_KEY=
KNOWLEDGE_GRAPH_DESCRIPTION_GEMINI_CONCURRENCY=4
KNOWLEDGE_GRAPH_DESCRIPTION_MAX_MONTHLY_USD=50.0

# EODHD API (Workers 13D-6, 13D-7, 13D-8 — PRD-0018)
# Set to your EODHD API key to enable economic events, macro indicators, and insider transaction enrichment.
KNOWLEDGE_GRAPH_EODHD_API_KEY=
KNOWLEDGE_GRAPH_EODHD_BASE_URL=https://eodhd.com/api
KNOWLEDGE_GRAPH_ECONOMIC_EVENT_COUNTRIES=US,DE,GB,JP,CN,EU
# ISO-3166 alpha-3 codes for macro indicator enrichment (Worker 13D-7)
KNOWLEDGE_GRAPH_MACRO_INDICATOR_COUNTRIES=USA,GBR,DEU,JPN,CHN

# AGE Cypher shadow sync (Worker 13F — PRD-0018, PLAN-0057 Wave E-3)
# Default flipped to true on 2026-05-01: AGE extension is loaded, AgeSyncWorker is registered,
# and the worker is idempotent (only catches up since the last watermark in Valkey).
# Initial backfill from epoch is heavy — first run should land during off-peak.
KNOWLEDGE_GRAPH_CYPHER_ENABLED=true

# Internal JWT auth (PRD-0025): InternalJWTMiddleware fetches JWKS from S9
KNOWLEDGE_GRAPH_API_GATEWAY_URL=http://localhost:8000

# DEF-022: embedding model tracking
# Recorded alongside every relation_summaries.summary_embedding write so the
# HNSW ANN index can be audited for mixed-model drift (see migration 0027).
KNOWLEDGE_GRAPH_SUMMARY_EMBEDDING_MODEL_ID=BAAI/bge-large-en-v1.5

# DEF-033: provisional enrichment exponential backoff
# Worker 13E sets next_retry_at = now() + min(base * 2^retry_count, max) minutes
# on every failed attempt so an LLM outage self-throttles instead of hammering
# the upstream API every 5 minutes.  Default base=2, max=1440 (24h).
KNOWLEDGE_GRAPH_PROVISIONAL_ENRICHMENT_BASE_RETRY_MINUTES=2
KNOWLEDGE_GRAPH_PROVISIONAL_ENRICHMENT_MAX_RETRY_MINUTES=1440
