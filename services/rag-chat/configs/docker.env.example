# S8 RAG/Chat Service — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile infra/all).
# Infrastructure hostnames resolve to Docker service names, not localhost.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

# ── Server ────────────────────────────────────────────────────────────────────
RAG_CHAT_HOST=0.0.0.0
RAG_CHAT_PORT=8008
RAG_CHAT_DEBUG=false

# ── Database (Docker internal: postgres:5432) ─────────────────────────────────
RAG_CHAT_RAG_DB_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/rag_db
# RAG_CHAT_RAG_DB_URL_READ=  # omit to reuse write URL

# ── Valkey (Docker internal: valkey:6379) ─────────────────────────────────────
RAG_CHAT_VALKEY_URL=redis://valkey:6379/0

# ── Ollama (Docker internal: ollama:11434) ────────────────────────────────────
RAG_CHAT_OLLAMA_BASE_URL=http://ollama:11434
RAG_CHAT_OLLAMA_CLASSIFICATION_MODEL=qwen2.5:3b
RAG_CHAT_OLLAMA_RERANKER_MODEL=bge-reranker-v2-m3

# ── LLM API providers ─────────────────────────────────────────────────────────
# DeepInfra powers the WHOLE ML pipeline behind ONE account key. That same key is
# duplicated under different env-var names across rag-chat, nlp-pipeline,
# knowledge-graph and api-gateway. Full var→service map + rotation runbook:
#   infra/gitops/docs/deepinfra-key-rotation.md
# When rotating, update ALL of them together in the worldview-gitops source of
# truth — otherwise a fresh `make dev` reintroduces the dead key. NEVER commit the
# real key here; it lives only in docker.env (gitignored), copied from gitops.
# RAG_CHAT_DEEPINFRA_API_KEY=your-key-here
# RAG_CHAT_OPENROUTER_API_KEY=your-key-here

# ── Upstream services (Docker internal hostnames) ─────────────────────────────
RAG_CHAT_S6_BASE_URL=http://nlp-pipeline:8006
RAG_CHAT_S7_BASE_URL=http://knowledge-graph:8007
RAG_CHAT_S3_BASE_URL=http://market-data:8003
RAG_CHAT_S1_BASE_URL=http://portfolio:8001
RAG_CHAT_S1_INTERNAL_TOKEN=dev-internal-token

# ── Rate limiting ─────────────────────────────────────────────────────────────
RAG_CHAT_RATE_LIMIT_PER_TENANT=10
RAG_CHAT_UPSTREAM_TIMEOUT_SECONDS=5.0

# ── get_filings retrieval depth (R1 filings-chat fix, 2026-07-06) ─────────────
# Inject the top-N chunks per filing, biased toward the numeric-dense
# financial-statement chunk, so the model can quote real revenue/segment
# figures (not just the filing cover/section-listing header). Bounded per-filing.
RAG_CHAT_FILING_CHUNKS_PER_FILING=3
RAG_CHAT_FILING_SNIPPET_MAX_CHARS=1200
RAG_CHAT_FILING_RESULT_MAX_CHARS=6000
# NEW-1 refinement (2026-07-06): cover/header window (chars, from a chunk start /
# before a registrant-charter line) in which the queried company must be named for
# a filing to count as THAT company's filing — stops a competitor body mention
# (41 AMD chunks name "nvidia") corroborating the wrong filer. 80–2000.
RAG_CHAT_FILING_FILER_HEADER_CHARS=400
# NEW-3 refinement (2026-07-06): when a filing's material figure is quoted verbatim
# but the model omitted the provenance marker, append its citation deterministically
# (was flaky 1-vs-0 run-to-run). Set to "false" to disable. Hot-toggle (per-call).
RAG_CHAT_FILING_CITATION_BACKFILL=true

# ── Observability ─────────────────────────────────────────────────────────────
RAG_CHAT_LOG_LEVEL=INFO
RAG_CHAT_LOG_JSON=true
RAG_CHAT_OTLP_ENDPOINT=

# Auth
# Skip JWKS fetch in test/dev compose profiles that have no api-gateway container.
RAG_CHAT_INTERNAL_JWT_SKIP_VERIFICATION=true

# PLAN-0076 Sub-Plan A security gate: when INTERNAL_JWT_SKIP_VERIFICATION=true
# (local dev / compose), APP_ENV must be set to one of:
#   development | dev | test | ci | local
# Production deployments leave INTERNAL_JWT_SKIP_VERIFICATION unset (false) and
# do not need APP_ENV for this guard.
APP_ENV=development

# ── Brief pre-generation (PLAN-0094 W2) ───────────────────────────────────────
# Pre-generates morning briefs for users seen authenticating in the last
# ACTIVE_WINDOW_DAYS days, every INTERVAL_HOURS hours.  Production cadence is
# 24h; dev typically overrides to 1h for fast feedback.
# Brief-scheduler service-account secret (PLAN-0094 W2 follow-up). Must match
# API_GATEWAY_SERVICE_ACCOUNT_TOKEN. Empty falls back to /v1/auth/dev-login
# (blocked in prod). Set in worldview-gitops prod env.
RAG_CHAT_SERVICE_ACCOUNT_TOKEN=

RAG_CHAT_BRIEF_PREGEN_ENABLED=true
RAG_CHAT_BRIEF_PREGEN_INTERVAL_HOURS=24
RAG_CHAT_BRIEF_PREGEN_ACTIVE_WINDOW_DAYS=7
RAG_CHAT_BRIEF_PREGEN_BATCH_SIZE=50
RAG_CHAT_BRIEF_PREGEN_CONCURRENCY=4
RAG_CHAT_BRIEF_FRESH_TTL_HOURS=30
RAG_CHAT_BRIEF_LAST_GOOD_TTL_DAYS=7

# ── Agentic brief generator (PLAN-0099 Wave C — experimental, off by default) ─
# Iterative LLM tool-use loop alternative to the single-turn standard generator.
# Falls back to the standard generator on any exception or tool-call budget overrun.
# Intended for A/B comparison only — DO NOT enable in production without QA.
RAG_CHAT_BRIEF_AGENTIC_ENABLED=false
RAG_CHAT_BRIEF_AGENTIC_MAX_TOOL_CALLS=8
