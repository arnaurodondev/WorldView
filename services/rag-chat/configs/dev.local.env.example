# S8 RAG/Chat Service — Local Development Environment
# Copy to .env and adjust as needed

# ── Server ────────────────────────────────────────────────────────────────────
RAG_CHAT_HOST=0.0.0.0
RAG_CHAT_PORT=8008
RAG_CHAT_DEBUG=true

# ── Database (R23 dual-URL) ───────────────────────────────────────────────────
RAG_CHAT_RAG_DB_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/rag_db
# RAG_CHAT_RAG_DB_URL_READ=   # omit to reuse write URL

# ── Valkey ────────────────────────────────────────────────────────────────────
RAG_CHAT_VALKEY_URL=redis://localhost:6379/0

# ── Ollama ────────────────────────────────────────────────────────────────────
RAG_CHAT_OLLAMA_BASE_URL=http://localhost:11434
RAG_CHAT_OLLAMA_CLASSIFICATION_MODEL=qwen2.5:3b
RAG_CHAT_OLLAMA_RERANKER_MODEL=bge-reranker-v2-m3

# ── LLM API providers ─────────────────────────────────────────────────────────
# RAG_CHAT_DEEPINFRA_API_KEY=your-key-here
# RAG_CHAT_OPENROUTER_API_KEY=your-key-here

# ── Completion model config (PRD-0016 §6.2) ───────────────────────────────────
RAG_CHAT_COMPLETION_PROVIDER=deepinfra
RAG_CHAT_COMPLETION_MODEL=deepseek-r1-distill-qwen-32b

# ── Internal service auth (briefing endpoint) ─────────────────────────────────
RAG_CHAT_INTERNAL_SERVICE_TOKEN=dev-briefing-token

# ── Upstream services ─────────────────────────────────────────────────────────
RAG_CHAT_S6_BASE_URL=http://localhost:8006
RAG_CHAT_S7_BASE_URL=http://localhost:8007
RAG_CHAT_S3_BASE_URL=http://localhost:8003
RAG_CHAT_S1_BASE_URL=http://localhost:8001
RAG_CHAT_S1_INTERNAL_TOKEN=dev-internal-token

# ── Feature flags ─────────────────────────────────────────────────────────────
RAG_CHAT_CYPHER_ENABLED=false

# ── Rate limiting ─────────────────────────────────────────────────────────────
RAG_CHAT_RATE_LIMIT_PER_TENANT=10
RAG_CHAT_UPSTREAM_TIMEOUT_SECONDS=5.0

# ── Observability ─────────────────────────────────────────────────────────────
RAG_CHAT_LOG_LEVEL=DEBUG
RAG_CHAT_LOG_JSON=false
RAG_CHAT_OTLP_ENDPOINT=
