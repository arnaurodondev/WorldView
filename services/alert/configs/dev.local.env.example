# S10 Alert Service — Local Development Environment
# Copy to dev.local.env and adjust as needed

ALERT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/alert_db
ALERT_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ALERT_KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081
ALERT_S1_PORTFOLIO_BASE_URL=http://localhost:8001
ALERT_VALKEY_URL=redis://localhost:6379/0
ALERT_ALERT_DEDUP_WINDOW_SECONDS=300
ALERT_WATCHLIST_CACHE_TTL_SECONDS=300
ALERT_PENDING_ALERT_TTL_DAYS=7

# Severity classification thresholds (PRD-0021 §6.5)
ALERT_ALERT_SEVERITY_CRITICAL_THRESHOLD=0.85
ALERT_ALERT_SEVERITY_HIGH_THRESHOLD=0.65
ALERT_ALERT_SEVERITY_MEDIUM_THRESHOLD=0.40
ALERT_ADMIN_TOKEN=dev-admin-token
# Internal JWT auth (PRD-0025): S9 fetches JWKS from this URL at startup
ALERT_API_GATEWAY_URL=http://localhost:8000

# Email provider (resend | sendgrid | smtp)
ALERT_EMAIL_PROVIDER=smtp
ALERT_EMAIL_FROM_ADDRESS=noreply@localhost
ALERT_RESEND_API_KEY=
ALERT_SENDGRID_API_KEY=
ALERT_SMTP_HOST=localhost
ALERT_SMTP_PORT=1025
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=

# Email scheduler
ALERT_S8_BASE_URL=http://localhost:8008

# Observability
ALERT_LOG_LEVEL=DEBUG
ALERT_LOG_JSON=false
ALERT_OTLP_ENDPOINT=
