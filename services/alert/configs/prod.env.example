# alert — Production Environment (fill in actual values)
# Copy to docker.env via worldview-gitops/scripts/setup-prod.sh
# All hostnames use Docker Compose service names (Docker-internal network).
# Port 8010 is NOT exposed directly — Traefik routes wss://${DOMAIN}/ws through Traefik labels.

ALERT_HOST=0.0.0.0
ALERT_PORT=8010
ALERT_DEBUG=false
ALERT_LOG_LEVEL=INFO
ALERT_LOG_JSON=true

# Database (internal Docker hostname)
ALERT_DATABASE_URL=postgresql+asyncpg://postgres:<POSTGRES_PASSWORD>@postgres:5432/alert_db

# Kafka (internal Docker hostname)
ALERT_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
ALERT_KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081
ALERT_KAFKA_CONSUMER_GROUP=alert-service-group
ALERT_KAFKA_WATCHLIST_CONSUMER_GROUP=alert-service-watchlist-group
ALERT_KAFKA_TOPIC_SIGNAL=nlp.signal.detected.v1
ALERT_KAFKA_TOPIC_GRAPH_STATE=graph.state.changed.v1
ALERT_KAFKA_TOPIC_CONTRADICTION=intelligence.contradiction.v1
ALERT_KAFKA_TOPIC_WATCHLIST=portfolio.watchlist.updated.v1
ALERT_KAFKA_TOPIC_ALERT_DELIVERED=alert.delivered.v1
ALERT_KAFKA_DLQ_TOPIC=alert.dead-letter.v1

# Valkey (internal Docker hostname)
ALERT_VALKEY_URL=redis://valkey:6379/0

# Upstream services (internal Docker hostnames)
ALERT_S1_PORTFOLIO_BASE_URL=http://portfolio:8000
ALERT_S8_BASE_URL=http://rag-chat:8008
ALERT_S3_MARKET_DATA_BASE_URL=http://market-data:8003

# Internal JWT for service-to-service calls (RS256, system role)
# Generate a long-lived token with: scripts/generate-dev-jwt.py --subject system --jti prod-alert-s1-jwt --expiry 365
# In production these should be short-lived (24h) and rotated via a scheduled job.
ALERT_S1_INTERNAL_JWT=<RS256-JWT>
ALERT_S8_INTERNAL_JWT=<RS256-JWT>
# S7 (knowledge-graph) entity resolver — REQUIRED for human-readable alert titles.
# Without it the resolver returns (None, None) and titles lose their ticker subject.
ALERT_S7_KNOWLEDGE_GRAPH_BASE_URL=http://knowledge-graph:8007
ALERT_S7_INTERNAL_JWT=<RS256-JWT>

# Email (real SMTP — switch ALERT_EMAIL_PROVIDER to smtp)
ALERT_EMAIL_PROVIDER=smtp
ALERT_EMAIL_FROM_ADDRESS=alerts@<DOMAIN>
ALERT_SMTP_HOST=<smtp-host>
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=<smtp-user>
ALERT_SMTP_PASSWORD=<smtp-password>

# Alert behaviour
ALERT_ALERT_DEDUP_WINDOW_SECONDS=300
ALERT_PENDING_ALERT_TTL_DAYS=7
ALERT_WATCHLIST_CACHE_TTL_SECONDS=300
ALERT_ALERT_SEVERITY_CRITICAL_THRESHOLD=0.85
ALERT_ALERT_SEVERITY_HIGH_THRESHOLD=0.65
ALERT_ALERT_SEVERITY_MEDIUM_THRESHOLD=0.40

# Security
ALERT_API_GATEWAY_URL=http://api-gateway:8000
ALERT_ADMIN_TOKEN=<GENERATE-RANDOM-TOKEN>

# Observability
ALERT_OTLP_ENDPOINT=http://tempo:4317
