# alert — Docker Compose Environment (example)
# Copy to docker.env and adjust values for your local setup.
# Used when the service runs INSIDE the Docker network (--profile alert-test).
# Infrastructure hostnames resolve to Docker service names, not localhost.

ALERT_HOST=0.0.0.0
ALERT_PORT=8010
ALERT_DEBUG=false

# Database (Docker internal hostname: postgres)
ALERT_DATABASE_URL=postgresql+asyncpg://postgres:postgres@postgres:5432/alert_db

# Kafka (Docker internal listener: kafka:29092)
ALERT_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
ALERT_KAFKA_SCHEMA_REGISTRY_URL=http://schema-registry:8081
ALERT_KAFKA_CONSUMER_GROUP=alert-service-group
ALERT_KAFKA_WATCHLIST_CONSUMER_GROUP=alert-service-watchlist-group

# Valkey (Docker internal hostname: valkey)
ALERT_VALKEY_URL=redis://valkey:6379/0

# Portfolio service dependency (S1)
ALERT_S1_PORTFOLIO_BASE_URL=http://portfolio:8000
INTERNAL_SERVICE_TOKEN=test-internal-token

# Security
ALERT_ADMIN_TOKEN=test-admin-token
# Skip JWKS fetch in test/dev compose profiles that have no api-gateway container.
ALERT_INTERNAL_JWT_SKIP_VERIFICATION=true

# Observability
ALERT_LOG_LEVEL=INFO
ALERT_LOG_JSON=true
ALERT_OTLP_ENDPOINT=
