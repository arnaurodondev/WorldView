# market-data — Local Development Environment
MARKET_DATA_HOST=0.0.0.0
MARKET_DATA_PORT=8003
MARKET_DATA_DEBUG=true
MARKET_DATA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/market_data_db
MARKET_DATA_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MARKET_DATA_SCHEMA_REGISTRY_URL=http://localhost:8081
MARKET_DATA_STORAGE_ENDPOINT=http://localhost:7480
MARKET_DATA_STORAGE_ACCESS_KEY=minioadmin
MARKET_DATA_STORAGE_SECRET_KEY=minioadmin
MARKET_DATA_VALKEY_URL=redis://localhost:6379/0
# Optional: route read-only API queries to a separate DB (e.g. a streaming replica).
# When unset, reads use MARKET_DATA_DATABASE_URL.
# MARKET_DATA_READ_REPLICA_URL=postgresql+asyncpg://postgres:postgres@replica:5432/market_data_db

# Internal JWT auth (PRD-0025): InternalJWTMiddleware fetches JWKS from S9
MARKET_DATA_API_GATEWAY_URL=http://localhost:8000

# EODHD on-demand enrichment (PLAN-0073 Wave B — on-demand-profile endpoint)
# Leave empty in dev; set to a real key to enable live EODHD calls
MARKET_DATA_EODHD_API_KEY=
MARKET_DATA_EODHD_BASE_URL=https://eodhd.com

# PLAN-0056 Wave D1 — PredictionMoveDetector worker (material implied-probability
# move signals → market.prediction.move.v1 via the outbox). All gates are
# env-driven so the noise floor can be re-tuned without a redeploy.
MARKET_DATA_PREDICTION_MOVE_DETECTOR_INTERVAL_SECONDS=900
MARKET_DATA_PREDICTION_MOVE_WINDOW_HOURS=24
MARKET_DATA_PREDICTION_MOVE_INTERVAL_LABEL=1d
# Δ gate: min absolute implied-probability swing (0-1). 0.15 = 15 pts.
MARKET_DATA_PREDICTION_MOVE_DELTA_THRESHOLD=0.15
# Liquidity/volume floors (USD) on the latest snapshot — thin markets are noise.
MARKET_DATA_PREDICTION_MOVE_MIN_LIQUIDITY_USD=5000
MARKET_DATA_PREDICTION_MOVE_MIN_VOLUME_USD=1000
# Per-cycle safety caps (markets scanned per page / snapshots pulled per market).
MARKET_DATA_PREDICTION_MOVE_MARKET_PAGE_SIZE=200
MARKET_DATA_PREDICTION_MOVE_SNAPSHOT_LIMIT=500
