# market-data — Local Development Environment
MARKET_DATA_HOST=0.0.0.0
MARKET_DATA_PORT=8003
MARKET_DATA_DEBUG=true
MARKET_DATA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/market_data_db
MARKET_DATA_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
MARKET_DATA_SCHEMA_REGISTRY_URL=http://localhost:8081
MARKET_DATA_STORAGE_ENDPOINT=http://localhost:7480
MARKET_DATA_STORAGE_ACCESS_KEY=minioadmin
MARKET_DATA_STORAGE_SECRET_KEY=minioadmin
MARKET_DATA_VALKEY_URL=redis://localhost:6379/0
# Optional: route read-only API queries to a separate DB (e.g. a streaming replica).
# When unset, reads use MARKET_DATA_DATABASE_URL.
# MARKET_DATA_READ_REPLICA_URL=postgresql+asyncpg://postgres:postgres@replica:5432/market_data_db
