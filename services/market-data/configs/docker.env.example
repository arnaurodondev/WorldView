# market-data — Docker Compose Environment
# Used when the service runs INSIDE the Docker network (--profile runtime).
# Infrastructure hostnames resolve to Docker service names, not localhost.
#
# Setup: cp configs/docker.env.example configs/docker.env
# For local FastAPI dev (make run), see: configs/dev.local.env.example

MARKET_DATA_HOST=0.0.0.0
MARKET_DATA_PORT=8003
MARKET_DATA_DEBUG=false

# Database (Docker internal hostname: timescaledb)
MARKET_DATA_DATABASE_URL=postgresql+asyncpg://postgres:postgres@timescaledb:5432/market_data_db

# Kafka (Docker internal listener: kafka:29092)
MARKET_DATA_KAFKA_BOOTSTRAP_SERVERS=kafka:29092
MARKET_DATA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Storage (MinIO — Docker internal: minio:9000)
MARKET_DATA_STORAGE_ENDPOINT=http://minio:9000
# Dev default — replace with real credentials for production (never commit real credentials)
MARKET_DATA_STORAGE_ACCESS_KEY=minioadmin
MARKET_DATA_STORAGE_SECRET_KEY=minioadmin

# Valkey (Docker internal hostname: valkey)
MARKET_DATA_VALKEY_URL=redis://valkey:6379/0

# PLAN-0066 Wave G: max date range for /api/v1/ohlcv/bars (days)
MARKET_DATA_OHLCV_MAX_DAYS=365

# Auth
# Skip JWKS fetch in test/dev compose profiles that have no api-gateway container.
MARKET_DATA_INTERNAL_JWT_SKIP_VERIFICATION=true

# PLAN-0093 A-1 / F-LIVE-001 — required: the startup_assert helper refuses to start
# when internal_jwt_skip_verification=True AND APP_ENV is unset.
APP_ENV=development
