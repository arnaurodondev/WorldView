# market-data — Production Environment (fill in actual values)
MARKET_DATA_HOST=0.0.0.0
MARKET_DATA_PORT=8003
MARKET_DATA_DEBUG=false

# Required: PostgreSQL (TimescaleDB) connection string (asyncpg driver)
MARKET_DATA_DATABASE_URL=postgresql+asyncpg://user:password@host:5432/market_data_db

# Required: Kafka
MARKET_DATA_KAFKA_BOOTSTRAP_SERVERS=broker1:9092,broker2:9092
MARKET_DATA_SCHEMA_REGISTRY_URL=http://schema-registry:8081

# Required: MinIO / S3-compatible object storage
MARKET_DATA_STORAGE_ENDPOINT=http://minio:9000
MARKET_DATA_STORAGE_ACCESS_KEY=
MARKET_DATA_STORAGE_SECRET_KEY=

# Required: Valkey (Redis-compatible) — used for quote cache
MARKET_DATA_VALKEY_URL=redis://valkey:6379/0

# Optional: OpenTelemetry tracing (omit to disable)
MARKET_DATA_OTLP_ENDPOINT=http://otel-collector:4317
