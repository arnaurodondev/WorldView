# apps/worldview-web/.npmrc — pnpm configuration
#
# WHY save-exact=true:
# When a developer runs `pnpm add <package>`, pnpm would by default add a "^"
# prefix (e.g., "^1.2.3"), allowing silent minor/patch upgrades that break
# reproducibility. save-exact=true pins to the exact installed version.
# This is the project-wide policy (per feedback_frontend_pnpm.md memory).
#
# WHY engine-strict=true:
# The package.json "engines" field specifies required Node/pnpm versions.
# Without engine-strict, version mismatches are silently ignored.
# With it, running the wrong Node or pnpm version fails with a clear error.
save-exact=true
engine-strict=true
