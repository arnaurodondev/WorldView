# worldview-web environment variables
# Copy to .env.local for local development.
# Never commit .env.local to version control.

# ── Backend API Gateway ──────────────────────────────────────────
# WHY: All API calls proxy through Next.js rewrites to this URL.
# In dev: S9 runs on localhost:8000 (Docker Compose or direct Python).
# In Docker Compose prod: http://api-gateway:8000 (Docker-internal, set in docker-compose.prod.yml).
# In Vercel split: https://api.${DOMAIN} (server-side fetch to public Hetzner URL).
API_GATEWAY_URL=http://localhost:8000

# ── WebSocket (direct to S10) ────────────────────────────────────
# WebSocket connects directly to S10 by design (ADR-F-02), not through Next.js rewrites.
# Frontend connects directly to S10 alert service for real-time alerts.
# Token is obtained from GET /v1/auth/ws-token (30s TTL, RS256 signed).
# CRITICAL: In production this MUST be wss:// (not ws://).
# ws:// = HTTP dev → no HTTPS security headers.
# wss:// = TLS deployment → enables upgrade-insecure-requests CSP + HSTS (BP-324).
NEXT_PUBLIC_WS_BASE_URL=ws://localhost:8010

# ── Application ──────────────────────────────────────────────────
NEXT_PUBLIC_APP_NAME=Worldview

# ── Zitadel OIDC ─────────────────────────────────────────────────
# Leave unset in local dev to use the Dev Login button (shown automatically
# when NEXT_PUBLIC_ZITADEL_URL is absent). Set for Zitadel PKCE testing.
# See infra/zitadel/README.md for local Zitadel setup.
# NEXT_PUBLIC_ZITADEL_URL=http://localhost:8088
# NEXT_PUBLIC_ZITADEL_CLIENT_ID=worldview-web

# ── Production: Hetzner Docker Compose ────────────────────────────────────────
# These are injected via docker-compose.prod.yml — do NOT set in .env.local.
#
# API_GATEWAY_URL=http://api-gateway:8000
# NEXT_PUBLIC_WS_BASE_URL=wss://ws.${DOMAIN}    ← must be wss://
# NEXT_PUBLIC_ZITADEL_URL=https://<instance>.zitadel.cloud
# NEXT_PUBLIC_ZITADEL_CLIENT_ID=<client-id>

# ── Sentry — Error Observability (PLAN-0065 T-D-03) ─────────────────────────
# Leave all blank in local dev — empty DSN puts the SDK in disabled mode (no-op).
# In production, set NEXT_PUBLIC_SENTRY_DSN to your Sentry project's DSN.
#
# WHY NEXT_PUBLIC_ prefix for DSN: The DSN is NOT a secret (it is embedded in the
# browser bundle and visible in devtools). The NEXT_PUBLIC_ prefix bakes it into
# the client-side JS at build time so the browser SDK can find it.
#
# SENTRY_AUTH_TOKEN is a BUILD-TIME secret (not runtime). It allows the Sentry
# webpack plugin to upload source maps so stack traces de-minify correctly.
# Set it in your CI environment, not here. Never commit a real token.
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
# SENTRY_AUTH_TOKEN=   ← build-time only; set in CI / Vercel build settings
# SENTRY_ORG=          ← your Sentry org slug (e.g. worldview)
# SENTRY_PROJECT=      ← your Sentry project slug (e.g. worldview-web)

# ── Production: Vercel split deployment ──────────────────────────────────────
# Set in Vercel → Settings → Environment Variables:
#
# API_GATEWAY_URL=https://api.${DOMAIN}          ← server-side: public HTTPS URL
# NEXT_PUBLIC_WS_BASE_URL=wss://ws.${DOMAIN}     ← baked at build time: must be wss://
# NEXT_PUBLIC_ZITADEL_URL=https://<instance>.zitadel.cloud
# NEXT_PUBLIC_ZITADEL_CLIENT_ID=<client-id>
# NEXT_PUBLIC_APP_NAME=Worldview
# NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...  ← baked into bundle
# NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
# SENTRY_AUTH_TOKEN=...                              ← build-time sourcemap upload
# SENTRY_ORG=worldview
# SENTRY_PROJECT=worldview-web
#
# See: infra/gitops/docs/vercel-deployment.md
