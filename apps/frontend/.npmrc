# Enforce pnpm — reject npm and yarn installs
engine-strict=true

# Pin exact versions on every install (no ^ or ~ drift)
save-exact=true

# Fail fast in CI if lockfile is out of sync
# (override to false locally when deliberately updating deps)
frozen-lockfile=false

# Run security audit on every install
audit=true

# Strict module isolation — no phantom dependency access
hoist=false
public-hoist-pattern[]=*types*
public-hoist-pattern[]=eslint*
public-hoist-pattern[]=prettier*
public-hoist-pattern[]=vitest*
public-hoist-pattern[]=@testing-library*
public-hoist-pattern[]=@vitejs*
public-hoist-pattern[]=vite*

# Disallow optional peer deps to silently fill security gaps
strict-peer-dependencies=false
