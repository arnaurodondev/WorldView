# Eval run results (timestamped/regenerable outputs — not source-of-truth artifacts).
# Already-tracked result sets stay tracked (gitignore only affects NEW files); commit a
# curated/thesis-evidence result set explicitly with `git add -f <path>` if needed.
results/eval_*.json
results/eval_*.csv
results/boost_sweep_*.json
results/routing_dataset/
# Per-experiment eval output dirs (extraction runs, A/Bs, model switches, llm audits, sweeps).
results/extraction_*/
results/*_ab/
results/*_ab_*/
results/*_dryrun/
results/model_switch_*/
results/gate_residual_*/
results/llm_audit_*/
results/recall_probe_*/

# Chat-quality benchmark generated artifacts. The framework code + curated gold set
# (gold_labels.yaml) ARE tracked; per-run outputs, the trend DB, and regenerated
# calibration reports are not.
tests/validation/chat_quality_benchmark/trend/
tests/validation/chat_quality_benchmark/gold/_calibration_report.*
tests/validation/chat_quality_benchmark/gold/REVIEW_SHEET.md

# QA / E2E capture artifacts committed under audit dirs (screenshots + captured payloads).
# Audit *.md reports stay tracked; the regenerable capture data does not.
docs/audits/**/qa-data*.json
docs/audits/**/qa-*.json
docs/audits/**/*.png
docs/audits/**/screenshots/
docs/audits/*-qa/
docs/audits/*-gaps/

